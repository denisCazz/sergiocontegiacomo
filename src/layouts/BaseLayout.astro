---
import '../styles/base.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';
import { siteConfig } from '../lib/config';
import Analytics from '@vercel/analytics/astro'

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  activePath?: string;
  showLoader?: boolean;
  keywords?: string;
  noindex?: boolean;
  article?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: unknown;
}

const {
  title,
  description,
  ogImage,
  canonical,
  activePath,
  showLoader = true,
  keywords,
  noindex = false,
  article = false,
  publishedTime,
  modifiedTime,
  structuredData,
} = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.name}` : `${siteConfig.name} - ${siteConfig.role}`;
const pageDescription = description ??
  'Consulenza patrimoniale su misura, coaching finanziario e percorsi di educazione economica per imprenditori e famiglie.';
const image = ogImage ?? '/sergio.avif';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const defaultKeywords = 'consulente patrimoniale, coach finanziario, educazione finanziaria, wealth management, pianificazione patrimoniale, Sergio Contegiacomo, Bra, Cuneo, Piemonte';
const gaMeasurementId = siteConfig.analytics?.gaMeasurementId?.trim();
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    
    <!-- SEO Meta -->
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="author" content="Sergio Contegiacomo" />
    <meta name="keywords" content={keywords ?? defaultKeywords} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={new URL(image, Astro.site ?? siteConfig.siteUrl).toString()} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="it_IT" />
    {article && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {article && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={new URL(image, Astro.site ?? siteConfig.siteUrl).toString()} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;600&family=Work+Sans:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;600&family=Work+Sans:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;600&family=Work+Sans:wght@400;500;600;700&display=swap"
      />
    </noscript>
    <link rel="icon" type="image/x-icon" href="/logo_sergio.ico" />

    {gaMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script is:inline>
          {`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaMeasurementId}', { anonymize_ip: true });`}
        </script>
      </>
    )}
    <!-- Schema.org FinancialService -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FinancialService",
        "name": "Sergio Contegiacomo - Consulente Patrimoniale",
        "image": "https://www.sergiocontegiacomo.it/sergio.avif",
        "@id": "https://www.sergiocontegiacomo.it",
        "url": "https://www.sergiocontegiacomo.it",
        "telephone": "+39 0172 44191",
        "email": "info@sergiocontegiacomo.it",
        "priceRange": "€€€",
        "description": "Consulenza patrimoniale, coaching finanziario e educazione economica per imprenditori e famiglie. Oltre 15 anni di esperienza nel private banking e wealth management.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Piazza Roma, 39",
          "addressLocality": "Bra",
          "addressRegion": "CN",
          "postalCode": "12042",
          "addressCountry": "IT"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 44.698,
          "longitude": 7.855
        },
        "areaServed": ["Piemonte", "Italia"],
        "sameAs": [
          "https://www.linkedin.com/in/sergio-contegiacomo-b180b921"
        ],
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Wednesday"],
            "opens": "08:30",
            "closes": "13:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Wednesday"],
            "opens": "18:00",
            "closes": "20:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Tuesday", "Friday"],
            "opens": "08:30",
            "closes": "13:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Thursday",
            "opens": "08:30",
            "closes": "12:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Thursday",
            "opens": "14:00",
            "closes": "18:00"
          }
        ]
      }
    </script>
    
    <!-- Schema.org Person -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Sergio Contegiacomo",
        "jobTitle": "Consulente Patrimoniale & Coach Finanziario",
        "description": "Consulente patrimoniale con oltre 15 anni di esperienza nel private banking. Coach finanziario ed educatore certificato.",
        "image": "https://www.sergiocontegiacomo.it/sergio.avif",
        "url": "https://www.sergiocontegiacomo.it",
        "email": "info@sergiocontegiacomo.it",
        "telephone": "+39 0172 44191",
        "sameAs": [
          "https://www.linkedin.com/in/sergio-contegiacomo-b180b921"
        ],
        "worksFor": {
          "@type": "Organization",
          "name": "Allianz Bank Financial Advisors",
          "url": "https://www.allianzbank.it"
        },
        "alumniOf": [
          {
            "@type": "EducationalOrganization",
            "name": "SDA Bocconi School of Management"
          }
        ],
        "hasCredential": [
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Wealth Planner",
            "credentialCategory": "Professional Certification"
          },
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Iscrizione ANASF",
            "credentialCategory": "Professional License"
          }
        ],
        "knowsAbout": [
          "Wealth Management",
          "Financial Planning",
          "Private Banking",
          "Financial Coaching",
          "Patrimony Governance"
        ],
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Bra",
          "addressRegion": "Piemonte",
          "addressCountry": "Italia"
        }
      }
    </script>

    {structuredData && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
      />
    )}
    <script>
      {`(() => {
        if (typeof window === 'undefined' || typeof document === 'undefined') {
          return;
        }

        // Use a new key to avoid old stored values forcing the site theme.
        // Default is light unless the user explicitly chooses otherwise.
        const storageKey = 'theme-preference';
        const legacyStorageKey = 'preferred-theme';
        const root = document.documentElement;

        const applyTheme = (theme) => {
          if (theme === 'dark') {
            root.classList.add('dark');
          } else {
            root.classList.remove('dark');
          }
          root.dataset.theme = theme;
        };

        const prefersDark = () => window.matchMedia('(prefers-color-scheme: dark)').matches;

        try {
          // Clear legacy key so it won't override OS defaults.
          if (localStorage.getItem(legacyStorageKey)) {
            localStorage.removeItem(legacyStorageKey);
          }

          const stored = localStorage.getItem(storageKey);
          const preference = stored === 'dark' || stored === 'light' || stored === 'auto' ? stored : null;
          const initialTheme = preference === 'dark' || preference === 'light'
            ? preference
            : preference === 'auto'
              ? (prefersDark() ? 'dark' : 'light')
              : 'light';

          applyTheme(initialTheme);

          const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
          const handlePreferredScheme = (event) => {
            // Follow OS only when the user explicitly chose auto.
            const pref = localStorage.getItem(storageKey);
            if (pref !== 'auto') return;
            applyTheme(event.matches ? 'dark' : 'light');
          };

          if (typeof mediaQuery.addEventListener === 'function') {
            mediaQuery.addEventListener('change', handlePreferredScheme);
          } else if (typeof mediaQuery.addListener === 'function') {
            mediaQuery.addListener(handlePreferredScheme);
          }
        } catch (error) {
          applyTheme('light');
        }
      })();`}
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-neutral-text dark:bg-neutral-950 dark:text-neutral-100">
    {showLoader && <PageLoader />}
    <Header activePath={activePath ?? Astro.url.pathname} />
    <main class="flex-1">
      <slot />
    </main>
    <Analytics />
    <Footer />
  </body>
</html>
