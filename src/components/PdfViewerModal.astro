---
interface Props {
  modalId: string;
  title: string;
  pdfUrl: string;
}

const { modalId, title, pdfUrl } = Astro.props;
const pdfSrc = `${pdfUrl}#toolbar=1&navpanes=0&scrollbar=1&view=FitH`;
---

<!--
  Usiamo <dialog> nativo + showModal(): il browser lo piazza nel "top layer",
  che è sopra TUTTO per specifica HTML — nessun z-index, nessun stacking context.
-->
<dialog
  id={modalId}
  data-pdf-dialog
  data-pdf-src={pdfSrc}
  class="m-auto w-[95vw] max-w-5xl rounded-2xl bg-white p-0 shadow-2xl backdrop:bg-black/70 dark:bg-neutral-950"
  style="height: min(88dvh, 820px); border: none; outline: none; overflow: hidden;"
>
  <div class="flex h-full flex-col">
    <!-- header -->
    <div class="flex shrink-0 items-center justify-between gap-3 bg-neutral-900 px-5 py-3">
      <h3 class="truncate text-sm font-bold uppercase tracking-widest text-white">{title}</h3>
      <div class="flex shrink-0 items-center gap-2">
        <a
          href={pdfUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-4 py-1.5 text-xs font-semibold text-white ring-1 ring-white/30 transition hover:bg-white/25"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6m0 0v6m0-6L10 14"/>
          </svg>
          Apri
        </a>
        <button
          type="button"
          data-pdf-close
          aria-label="Chiudi"
          class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-white ring-1 ring-white/20 transition hover:bg-white/25"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- viewer PDF: riempie tutto lo spazio restante -->
    <iframe
      data-pdf-frame
      title={title}
      class="min-h-0 flex-1 border-0 bg-white"
      referrerpolicy="strict-origin-when-cross-origin"
    ></iframe>
  </div>
</dialog>

<script>
  const w = window as Window & { __pdfDialogInit?: boolean };

  if (!w.__pdfDialogInit) {
    w.__pdfDialogInit = true;

    function openPdfDialog(dialog: HTMLDialogElement) {
      const frame = dialog.querySelector<HTMLIFrameElement>('[data-pdf-frame]');
      const src = dialog.dataset.pdfSrc ?? '';
      if (frame && src) frame.src = src;
      dialog.showModal();
      document.body.style.overflow = 'hidden';
    }

    function cleanupPdfDialog(dialog: HTMLDialogElement) {
      const frame = dialog.querySelector<HTMLIFrameElement>('[data-pdf-frame]');
      if (frame) frame.src = '';
      document.body.style.overflow = '';
    }

    // gestisce chiusura nativa (Escape o dialog.close()) — close non fa bubble
    document.addEventListener('close', (e) => {
      const el = e.target;
      if (el instanceof HTMLDialogElement && 'pdfDialog' in el.dataset) {
        cleanupPdfDialog(el);
      }
    }, true);

    document.addEventListener('click', (e) => {
      const t = e.target;
      if (!(t instanceof Element)) return;

      // pulsante/link trigger
      const trigger = t.closest<HTMLElement>('[data-pdf-modal-trigger]');
      if (trigger) {
        e.preventDefault();
        const id = trigger.dataset.pdfModalTrigger;
        if (!id) return;
        const dlg = document.getElementById(id);
        if (dlg instanceof HTMLDialogElement && 'pdfDialog' in dlg.dataset) {
          openPdfDialog(dlg);
        }
        return;
      }

      // pulsante chiudi dentro il dialog
      const closeBtn = t.closest<HTMLElement>('[data-pdf-close]');
      if (closeBtn) {
        const dlg = closeBtn.closest<HTMLDialogElement>('dialog');
        if (dlg) dlg.close();
        return;
      }

      // click sul backdrop (il target è il dialog stesso, fuori dal contenuto)
      if (t instanceof HTMLDialogElement && 'pdfDialog' in t.dataset) {
        t.close();
      }
    });
  }
</script>