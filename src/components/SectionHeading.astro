---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div
  class={`space-y-3 ${
    align === 'center'
      ? 'text-center mx-auto max-w-3xl'
      : 'text-left'
  }`}
>
  {eyebrow && (
    <p class="text-xs font-semibold uppercase tracking-[0.4em] text-brand-primary dark:text-brand-light">{eyebrow}</p>
  )}
  <h2 class="text-2xl md:text-3xl font-semibold text-neutral-text dark:text-white">{title}</h2>
  {description && <p class="text-neutral-muted leading-relaxed dark:text-neutral-300">{description}</p>}
</div>
