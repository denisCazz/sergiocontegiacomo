---
import dayjs from 'dayjs';
import 'dayjs/locale/it';
import type { EventItem } from '../lib/cms';
import { renderMarkdown } from '../lib/markdown';
import PdfViewerModal from './PdfViewerModal.astro';

interface Props {
  event: EventItem;
}

const { event } = Astro.props;
const formattedDate = dayjs(event.date).locale('it').format('DD MMM YYYY');
const isPast = dayjs(event.date).isBefore(dayjs(), 'day');
const htmlDescription = renderMarkdown(event.description);
const plainDescription = htmlDescription
  ? htmlDescription.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim()
  : undefined;
const truncatedDescription = plainDescription && plainDescription.length > 160
  ? `${plainDescription.slice(0, 157).trimEnd()}…`
  : plainDescription;
const pdfModalId = `event-pdf-modal-${event.slug}`;
---

<article class="group rounded-3xl border border-neutral-border bg-white overflow-hidden shadow-sm transition hover:shadow-card dark:border-neutral-800 dark:bg-neutral-900">
  {event.coverImage && (
    <div class="relative">
      {event.pdfUrl ? (
        <button
          type="button"
          data-pdf-modal-trigger={pdfModalId}
          class="relative block aspect-[16/9] w-full overflow-hidden text-left"
          aria-label={`Apri PDF dell'evento ${event.title}`}
        >
          <img
            src={event.coverImage}
            alt={`Immagine evento ${event.title}`}
            width="640"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent opacity-70 transition duration-300 group-hover:opacity-90"></div>
          <div class="absolute inset-x-0 bottom-0 px-5 pb-5 pt-14 text-white">
            <div class="max-w-[17rem]">
              <div class="pdf-glow-badge inline-flex items-center rounded-full border border-white/25 bg-white/18 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-white shadow-lg backdrop-blur-sm transition duration-300 group-hover:scale-105 group-hover:border-white/60 group-hover:bg-brand-primary group-hover:shadow-2xl group-hover:[animation:none]">
                Visualizza PDF
              </div>
            </div>
          </div>
        </button>
      ) : (
        <a href={`/eventi/${event.slug}`} class="relative block aspect-[16/9] overflow-hidden">
          <img
            src={event.coverImage}
            alt={`Immagine evento ${event.title}`}
            width="640"
            height="360"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
          />
        </a>
      )}
    </div>
  )}
  <div class="p-6 space-y-4">
    <div class="flex items-center gap-3 text-xs uppercase tracking-[0.3em] text-neutral-muted dark:text-neutral-400">
      <span>{formattedDate}</span>
      {event.time && <span>{event.time}</span>}
      <span>|</span>
      <span>{event.location}</span>
    </div>
    <div class="space-y-3">
      <a href={`/eventi/${event.slug}`} class="block">
        <h3 class="text-lg font-semibold text-neutral-text group-hover:text-brand-primary transition dark:text-white">
          {event.title}
        </h3>
      </a>
      {truncatedDescription && (
        <p class="text-sm text-neutral-muted leading-relaxed dark:text-neutral-300">{truncatedDescription}</p>
      )}
    </div>
    <div class="flex items-center justify-between text-xs text-neutral-muted dark:text-neutral-400">
      {event.price && <span>Costo: {event.price}</span>}
      <div class="flex items-center gap-2">
        {event.pdfUrl && (
          <button
            type="button"
            data-pdf-modal-trigger={pdfModalId}
            class="pdf-glow-btn inline-flex items-center gap-2 rounded-full border border-neutral-border px-4 py-1.5 text-xs font-semibold text-neutral-text transition hover:border-brand-primary hover:text-brand-primary hover:[animation:none] dark:border-neutral-700 dark:text-neutral-100"
          >
            PDF completo
          </button>
        )}
        {isPast ? (
          <span class="rounded-full bg-neutral-border px-3 py-1 text-neutral-muted dark:bg-neutral-800 dark:text-neutral-400">Evento terminato</span>
        ) : (
          <a
            href={`/eventi/${event.slug}`}
            class="inline-flex items-center gap-2 rounded-full bg-brand-primary px-4 py-1.5 text-white text-xs font-semibold hover:bg-brand-light transition"
          >
            Scopri di piu'
          </a>
        )}
      </div>
    </div>
  </div>
</article>
{event.pdfUrl && <PdfViewerModal modalId={pdfModalId} title={event.title} pdfUrl={event.pdfUrl} />}

<style>
  @keyframes pdf-glow-white {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.0); }
    50%       { box-shadow: 0 0 0 5px rgba(255,255,255,0.30); }
  }
  @keyframes pdf-glow-brand {
    0%, 100% { box-shadow: 0 0 0 0 rgba(var(--color-brand-primary, 99,102,241), 0.0); }
    50%       { box-shadow: 0 0 0 4px rgba(var(--color-brand-primary, 99,102,241), 0.30); }
  }
  .pdf-glow-badge {
    animation: pdf-glow-white 2.4s ease-in-out infinite;
  }
  .pdf-glow-btn {
    animation: pdf-glow-brand 2.4s ease-in-out infinite;
  }
</style>
