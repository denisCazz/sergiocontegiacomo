---
interface Props {
  title: string;
  description: string;
  items?: string[];
  ctaLabel?: string;
  ctaHref?: string;
}

const { title, description, items = [], ctaLabel, ctaHref } = Astro.props;
---

<div class="rounded-3xl border border-neutral-border bg-white p-8 shadow-sm transition hover:shadow-card dark:border-neutral-800 dark:bg-neutral-900">
  <h3 class="text-xl font-semibold text-neutral-text mb-4 dark:text-white">{title}</h3>
  <p class="text-neutral-muted text-sm leading-relaxed mb-6 dark:text-neutral-300">{description}</p>
  {items.length > 0 && (
    <ul class="space-y-3 text-sm text-neutral-muted dark:text-neutral-300">
      {items.map((item) => (
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2 w-2 rounded-full bg-brand-primary"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  )}
  {ctaLabel && ctaHref && (
    <a
      href={ctaHref}
      class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-primary hover:text-brand-light transition"
    >
      {ctaLabel}
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m9 5 7 7-7 7" />
      </svg>
    </a>
  )}
</div>
