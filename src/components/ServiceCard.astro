---
interface Props {
  title: string;
  description: string;
  items?: string[];
  ctaLabel?: string;
  ctaHref?: string;
  icon?: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, items = [], ctaLabel, ctaHref, icon, image, imageAlt } = Astro.props;

const icons: Record<string, string> = {
  costs: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="5" y="4" width="14" height="16" rx="2.2" /><path stroke-linecap="round" stroke-linejoin="round" d="M8 8h8M8 12h5" /><path stroke-linecap="round" stroke-linejoin="round" d="M10 16h6" /><path stroke-linecap="round" stroke-linejoin="round" d="m13.5 4.5 2 2m-7-2 2 2" /></svg>`,
  risk: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3 5 6v6.5c0 4 3.4 6.7 7 7.7 3.6-1 7-3.7 7-7.7V6z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v5" /><circle cx="12" cy="15.5" r="0.9" fill="currentColor" /></svg>`,
  returns: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M5 16.5 10.2 11l3.2 3.5 5.6-6.5" /><path stroke-linecap="round" stroke-linejoin="round" d="M14 8h5v5" /><path stroke-linecap="round" stroke-linejoin="round" d="M5 19h14" /></svg>`,
  tax: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M8 4h6l3 3.2V20a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1z" /><path stroke-linecap="round" stroke-linejoin="round" d="M14 4v4h4" /><path stroke-linecap="round" stroke-linejoin="round" d="M9 12c0-.9.7-1.7 1.6-1.7S12.2 11.1 12.2 12s-.7 1.7-1.6 1.7S9 12.9 9 12z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13 16.5c0-.9.7-1.7 1.6-1.7s1.6.8 1.6 1.7-.7 1.7-1.6 1.7S13 17.4 13 16.5z" /><path stroke-linecap="round" stroke-linejoin="round" d="m10 16.8 4-4.6" /></svg>`,
  protection: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3 6 5.3v6.6c0 3.8 2.8 7 6 8.1 3.2-1.1 6-4.3 6-8.1V5.3z" /><path stroke-linecap="round" stroke-linejoin="round" d="m9.5 12.2 2.1 2.1 3.1-3.6" /></svg>`,
};
---

<div class="relative rounded-3xl border border-neutral-border bg-white shadow-sm transition duration-300 hover:shadow-card hover:-translate-y-1 dark:border-neutral-800 dark:bg-neutral-900 overflow-hidden">
  {image && (
    <div class="absolute top-0 right-0 w-28 h-28 pointer-events-none">
      <img src={image} alt={imageAlt ?? title} class="w-full h-full object-contain opacity-20 dark:opacity-15" loading="lazy" />
    </div>
  )}
  <div class="relative z-10 p-8">
    <h3 class="text-xl font-semibold text-neutral-text mb-4 dark:text-white leading-tight">{title}</h3>
    <p class="text-neutral-muted text-sm leading-relaxed mb-6 dark:text-neutral-300">{description}</p>
    {items.length > 0 && (
      <ul class="space-y-3 text-sm text-neutral-muted dark:text-neutral-300">
        {items.map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 h-2 w-2 rounded-full bg-brand-primary"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    )}
    {ctaLabel && ctaHref && (
      <a
        href={ctaHref}
        class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-primary hover:text-brand-light transition"
      >
        {ctaLabel}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m9 5 7 7-7 7" />
        </svg>
      </a>
    )}
  </div>
</div>
