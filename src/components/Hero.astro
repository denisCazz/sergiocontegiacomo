---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryCta: {
    label: string;
    href: string;
  };
  secondaryCta?: {
    label: string;
    href: string;
  };
  stats?: Array<{ value: string; label: string }>;
}

const { eyebrow, title, description, primaryCta, secondaryCta, stats } = Astro.props;
---

<section class="relative overflow-hidden bg-neutral-base dark:bg-neutral-950">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-primary/10 via-transparent to-brand-light/10 dark:from-brand-dark/40 dark:via-transparent dark:to-brand-accent/20"></div>
  <div class="relative mx-auto max-w-6xl px-6 py-24 lg:py-32">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div class="space-y-8 animate-slide-up">
        {eyebrow && (
          <div class="inline-flex items-center gap-2 rounded-full bg-brand-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary dark:bg-brand-primary/20 dark:text-brand-light">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
            {eyebrow}
          </div>
        )}
        <div class="space-y-6">
          <h1 class="text-5xl md:text-7xl font-serif font-medium text-neutral-text leading-[1.1] dark:text-white tracking-tight">
            Fare la differenza è... <br/>
            <span class="text-brand-primary italic">la vera differenza.</span>
          </h1>
          <p class="text-xl md:text-2xl font-medium text-neutral-700 dark:text-neutral-200 max-w-xl leading-relaxed">
            {title}
          </p>
          <p class="text-base text-neutral-muted leading-relaxed dark:text-neutral-400 max-w-lg">
            {description}
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href={primaryCta.href}
            class="inline-flex items-center justify-center rounded-full bg-brand-primary px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-brand-primary/20 hover:bg-brand-light hover:-translate-y-0.5 transition duration-300"
          >
            {primaryCta.label}
          </a>
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center justify-center rounded-full border border-neutral-200 bg-white px-8 py-4 text-sm font-semibold text-neutral-700 hover:border-brand-primary hover:text-brand-primary transition duration-300 dark:bg-neutral-900 dark:border-neutral-800 dark:text-neutral-300 dark:hover:border-brand-light dark:hover:text-white"
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
        {stats && stats.length > 0 && (
          <dl class="grid grid-cols-2 gap-6 pt-8 border-t border-neutral-200 dark:border-neutral-800">
            {stats.map((item) => (
              <div>
                <dt class="text-xs uppercase tracking-wider text-neutral-500 dark:text-neutral-400 mb-1">{item.label}</dt>
                <dd class="text-3xl font-bold text-brand-primary dark:text-brand-light">{item.value}</dd>
              </div>
            ))}
          </dl>
        )}
      </div>
      <div class="relative lg:pl-10 animate-fade-in" style="animation-delay: 0.2s;">
        <div class="relative z-10 rounded-[2.5rem] overflow-hidden shadow-2xl shadow-brand-primary/10">
          <img
            src="/sergio.jpg"
            alt="Sergio Contegiacomo"
            fetchpriority="high"
            class="w-full h-auto object-cover transform hover:scale-105 transition duration-700 ease-out"
          />
        </div>
        
        <div class="absolute -top-10 -right-10 -z-10 h-64 w-64 rounded-full bg-brand-accent/10 blur-3xl dark:bg-brand-accent/5"></div>
        <div class="absolute -bottom-10 -left-10 -z-10 h-64 w-64 rounded-full bg-brand-primary/10 blur-3xl dark:bg-brand-primary/5"></div>
      </div>
    </div>
  </div>
</section>
