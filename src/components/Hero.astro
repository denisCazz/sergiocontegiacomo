---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryCta: {
    label: string;
    href: string;
  };
  secondaryCta?: {
    label: string;
    href: string;
  };
  stats?: Array<{ value: string; label: string }>;
}

const { eyebrow, title, description, primaryCta, secondaryCta, stats } = Astro.props;
---

<section class="relative overflow-hidden bg-neutral-base dark:bg-neutral-950">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-primary/10 via-transparent to-brand-light/10 dark:from-brand-dark/40 dark:via-transparent dark:to-brand-accent/20"></div>
  <div class="relative mx-auto max-w-6xl px-6 py-20 lg:py-28">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-7 space-y-8 animate-slide-up">
        {eyebrow && (
          <div class="inline-flex items-center gap-2 rounded-full bg-brand-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary dark:bg-brand-primary/20 dark:text-brand-light">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
            {eyebrow}
          </div>
        )}
        <div class="space-y-5">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-serif font-medium text-neutral-text leading-snug md:leading-normal dark:text-white tracking-tight">
             "Nella <span class="text-brand-primary">consulenza patrimoniale olistica</span> gli aspetti <span class="text-brand-primary">legali</span>, <span class="text-brand-primary">fiscali</span> ed <span class="text-brand-primary">assicurativi</span>
            <span class="italic block mt-1">vengono <span class="text-brand-primary font-semibold">prima di tutto il resto</span>"</span>
          </h1>
          <p class="text-lg md:text-xl font-medium text-neutral-700 dark:text-neutral-200 max-w-2xl leading-relaxed">
            {title}
          </p>
          <p class="text-base text-neutral-muted leading-relaxed dark:text-neutral-400 max-w-xl">
            {description}
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href={primaryCta.href}
            class="inline-flex items-center justify-center rounded-full bg-brand-primary px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-brand-primary/20 hover:bg-brand-light hover:-translate-y-0.5 transition duration-300"
          >
            {primaryCta.label}
          </a>
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="inline-flex items-center justify-center rounded-full border border-neutral-200 bg-white px-8 py-4 text-sm font-semibold text-neutral-700 hover:border-brand-primary hover:text-brand-primary transition duration-300 dark:bg-neutral-900 dark:border-neutral-800 dark:text-neutral-300 dark:hover:border-brand-light dark:hover:text-white"
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
        {stats && stats.length > 0 && (
          <div class="pt-8 border-t border-neutral-200 dark:border-neutral-800">
            <dl class="grid grid-cols-3 gap-6">
              {stats.map((item) => (
                <div class="text-center sm:text-left">
                  <dd class="text-4xl md:text-5xl font-bold text-brand-primary dark:text-brand-light mb-1">{item.value}</dd>
                  <dt class="text-xs uppercase tracking-wider text-neutral-500 dark:text-neutral-400">{item.label}</dt>
                </div>
              ))}
            </dl>
            <div class="mt-6 flex items-center gap-2 text-xs text-neutral-500 dark:text-neutral-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <span>Iscritto all'Albo dei Consulenti Finanziari — Delibera CONSOB n. 7413 del 28/09/1993</span>
            </div>
          </div>
        )}
      </div>
      <div class="lg:col-span-5 lg:self-start lg:-mt-4 relative animate-fade-in" style="animation-delay: 0.2s;">
        <div class="relative z-10 rounded-[2rem] overflow-hidden shadow-2xl shadow-brand-primary/20 border-4 border-white/50 dark:border-neutral-800/50">
          <img
            src="/sergio.avif"
            alt="Sergio Contegiacomo - Consulente Patrimoniale e Coach Finanziario"
            width="600"
            height="750"
            fetchpriority="high"
            decoding="async"
            class="w-full h-auto object-cover transform hover:scale-105 transition duration-700 ease-out"
            style="aspect-ratio: 600/750;"
          />
        </div>
        
        <div class="absolute -top-8 -right-8 -z-10 h-48 w-48 rounded-full bg-brand-primary/20 blur-3xl dark:bg-brand-primary/10"></div>
        <div class="absolute -bottom-8 -left-8 -z-10 h-48 w-48 rounded-full bg-brand-accent/20 blur-3xl dark:bg-brand-accent/10"></div>
      </div>
    </div>
  </div>
</section>
