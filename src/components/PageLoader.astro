---
/**
 * PageLoader Component
 * Mostra uno skeleton animato durante il caricamento della pagina
 * Da inserire nel BaseLayout per applicarlo automaticamente a tutte le pagine
 */
---

<!-- Full Page Skeleton Loader -->
<div id="page-loader" class="fixed inset-0 z-[9999] bg-white dark:bg-neutral-950 transition-opacity duration-500">
  <div class="min-h-screen">
    <!-- Header Skeleton -->
    <div class="border-b border-neutral-100 dark:border-neutral-800">
      <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
        <div class="h-8 w-40 rounded-lg bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
        <div class="hidden md:flex items-center gap-6">
          <div class="h-4 w-20 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
          <div class="h-4 w-20 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
          <div class="h-4 w-20 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
          <div class="h-4 w-20 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
        </div>
        <div class="h-10 w-32 rounded-full bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
      </div>
    </div>
    
    <!-- Hero Section Skeleton -->
    <div class="py-24 lg:py-32 px-6">
      <div class="mx-auto max-w-6xl">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Text Content -->
          <div class="space-y-8">
            <div class="h-6 w-28 rounded-full bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
            <div class="space-y-4">
              <div class="h-12 lg:h-16 w-full rounded-xl bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
              <div class="h-12 lg:h-16 w-4/5 rounded-xl bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
            </div>
            <div class="space-y-3">
              <div class="h-5 w-full rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
              <div class="h-5 w-5/6 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
              <div class="h-5 w-4/5 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
            </div>
            <div class="flex gap-4 pt-4">
              <div class="h-12 w-40 rounded-full bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
              <div class="h-12 w-32 rounded-full bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
            </div>
          </div>
          
          <!-- Image Placeholder -->
          <div class="hidden lg:block">
            <div class="aspect-[4/5] rounded-[2.5rem] bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Content Cards Skeleton -->
    <div class="py-16 px-6 bg-neutral-50 dark:bg-neutral-900">
      <div class="mx-auto max-w-6xl">
        <div class="text-center mb-12">
          <div class="h-6 w-32 rounded-full bg-neutral-200 dark:bg-neutral-700 animate-pulse mx-auto mb-4"></div>
          <div class="h-10 w-80 rounded-xl bg-neutral-200 dark:bg-neutral-700 animate-pulse mx-auto mb-4"></div>
          <div class="h-5 w-96 max-w-full rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse mx-auto"></div>
        </div>
        
        <div class="grid md:grid-cols-3 gap-8">
          {[1, 2, 3].map(() => (
            <div class="rounded-3xl border border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 p-8">
              <div class="h-16 w-16 rounded-2xl bg-neutral-200 dark:bg-neutral-700 animate-pulse mb-6"></div>
              <div class="h-6 w-32 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse mb-4"></div>
              <div class="space-y-2">
                <div class="h-4 w-full rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
                <div class="h-4 w-5/6 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
                <div class="h-4 w-4/5 rounded bg-neutral-200 dark:bg-neutral-700 animate-pulse"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }
  
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  #page-loader.fade-out {
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  // Hide loader when page is ready
  const hideLoader = () => {
    const loader = document.getElementById('page-loader');
    if (loader) {
      loader.classList.add('fade-out');
      setTimeout(() => {
        loader.style.display = 'none';
      }, 500);
    }
  };

  // Try to hide as soon as DOM is interactive
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      // Small delay to show the skeleton briefly
      setTimeout(hideLoader, 200);
    });
  } else {
    setTimeout(hideLoader, 200);
  }

  // Fallback: hide when everything is loaded
  window.addEventListener('load', hideLoader);
</script>
