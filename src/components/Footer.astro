---
import { siteConfig } from '../lib/config';
---

<footer class="bg-neutral-text/5 border-t border-neutral-border dark:bg-neutral-950/40 dark:border-neutral-800">
  <div class="mx-auto max-w-6xl px-6 py-12 grid gap-10 md:grid-cols-4 text-sm">
    <div class="space-y-3">
      <div class="flex items-center gap-3">
        <img src="/logo_sergio.avif" alt="Logo Sergio Contegiacomo" class="h-12 w-auto rounded-full" />
        <div>
          <p class="text-base font-semibold text-neutral-text dark:text-white">{siteConfig.name}</p>
          <p class="text-xs text-neutral-muted dark:text-neutral-300">{siteConfig.role}</p>
        </div>
      </div>
      <p class="text-neutral-muted leading-relaxed dark:text-neutral-300">
        Supporto strategico a famiglie e imprenditori per proteggere e far crescere il patrimonio nel tempo.
      </p>
      <div class="flex gap-3 text-neutral-muted dark:text-neutral-300">
        <a href={siteConfig.social.linkedin} aria-label="LinkedIn" class="hover:text-brand-primary transition">LinkedIn</a>
        <a href={siteConfig.social.youtube} aria-label="YouTube" class="hover:text-brand-primary transition">YouTube</a>
        <a href={siteConfig.social.instagram} aria-label="Instagram" class="hover:text-brand-primary transition">Instagram</a>
      </div>
    </div>
    <div class="space-y-3">
      <p class="text-sm font-semibold text-neutral-text uppercase tracking-[0.2em] dark:text-white">Studio</p>
      <p class="text-neutral-muted leading-relaxed dark:text-neutral-300">
        {siteConfig.address}<br />
        <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="block hover:text-brand-primary transition">{siteConfig.phone}</a>
        <a href="tel:3339877939" class="block hover:text-brand-primary transition">333 987 7939</a>
        <a href={`mailto:${siteConfig.contactEmail}`} class="block hover:text-brand-primary transition">{siteConfig.contactEmail}</a>
      </p>
    </div>
    <div class="space-y-3">
      <p class="text-sm font-semibold text-neutral-text uppercase tracking-[0.2em] dark:text-white">Pagine</p>
      <div class="flex flex-col gap-2 text-neutral-muted dark:text-neutral-300">
        <a href="/chi-sono" class="hover:text-brand-primary transition">Chi Sono</a>
        <a href="/cosa-faccio" class="hover:text-brand-primary transition">Cosa Faccio</a>
        <a href="/blog" class="hover:text-brand-primary transition">Blog</a>
        <a href="/eventi" class="hover:text-brand-primary transition">Eventi</a>
        <a href="/contatti" class="hover:text-brand-primary transition">Contatti</a>
      </div>
    </div>
    <div class="space-y-4">
      <p class="text-sm font-semibold text-neutral-text uppercase tracking-[0.2em] dark:text-white">Newsletter</p>
      <p class="text-neutral-muted text-sm leading-relaxed dark:text-neutral-300">
        Pillole di cultura finanziaria e aggiornamenti sugli eventi esclusivi, direttamente nella tua inbox.
      </p>
  <form id="newsletter" class="space-y-3" data-newsletter data-endpoint={siteConfig.newsletterEndpoint}>
        <label class="block text-xs font-semibold text-neutral-muted uppercase tracking-[0.3em]" for="newsletter-email">
          Email
        </label>
        <div class="hidden" aria-hidden="true">
          <label for="newsletter-company">Company</label>
          <input id="newsletter-company" name="company" type="text" tabindex="-1" autocomplete="off" />
        </div>
        <input
          id="newsletter-email"
          name="email"
          type="email"
          required
          class="w-full rounded-full border border-neutral-border bg-white px-4 py-2.5 text-sm focus:border-brand-primary focus:outline-none dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-100"
          placeholder="nome@esempio.it"
        />
        <button
          type="submit"
          class="w-full rounded-full bg-brand-primary px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-light transition"
        >
          Iscriviti
        </button>
        <p class="text-xs text-neutral-muted dark:text-neutral-400" data-feedback hidden>
          Grazie! Riceverai un'email di conferma entro pochi minuti.
        </p>
      </form>
    </div>
  </div>
  <div class="border-t border-neutral-border py-4 dark:border-neutral-800">
    <div class="mx-auto max-w-6xl px-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-neutral-muted dark:text-neutral-400">
      <div class="flex flex-col md:flex-row items-center gap-1 md:gap-4 text-center md:text-left">
        <p>&copy; {new Date().getFullYear()} {siteConfig.name}. Tutti i diritti riservati.</p>
        <span class="hidden md:inline text-neutral-300 dark:text-neutral-700">|</span>
        <p>Realizzato da <a href="https://bitora.it" target="_blank" rel="noopener noreferrer" class="hover:text-brand-primary transition">Bitora.it</a> - un prodotto di Cazzulo Denis</p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="hover:text-brand-primary transition">Privacy</a>
        <a href="/cookie" class="hover:text-brand-primary transition">Cookie</a>
        <a href="/admin" class="hover:text-brand-primary transition">Admin</a>
        <button
          type="button"
          class="inline-flex items-center gap-2 rounded-full border border-neutral-border bg-white px-3 py-1.5 text-xs font-semibold text-neutral-muted transition hover:border-brand-primary hover:text-brand-primary dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-300"
          data-theme-toggle
          aria-label="Cambia tema"
          title="Cambia tema"
        >
          <span data-theme-icon="auto" class="inline-flex items-center gap-2">
            <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-neutral-border text-[10px] leading-none dark:border-neutral-700">A</span>
            Automatico
          </span>
          <span data-theme-icon="sun" class="hidden inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="m4.93 4.93 1.41 1.41" />
              <path d="m17.66 17.66 1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="m6.34 17.66-1.41 1.41" />
              <path d="m19.07 4.93-1.41 1.41" />
            </svg>
            Tema chiaro
          </span>
          <span data-theme-icon="moon" class="hidden inline-flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
            </svg>
            Tema scuro
          </span>
        </button>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  (() => {
    const newsletterForm = document.querySelector('[data-newsletter]');
    const feedback = document.querySelector('[data-feedback]');
    const endpoint = newsletterForm?.getAttribute?.('data-endpoint') || '/api/newsletter';

    newsletterForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!(newsletterForm instanceof HTMLFormElement)) return;

      const formData = new FormData(newsletterForm);
      const email = formData.get('email');
      const company = formData.get('company');

      if (!email) return;

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email, company }),
        });

        const json = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(json?.message || 'Request failed');

        if (feedback instanceof HTMLElement) {
          feedback.hidden = false;
          feedback.textContent = json?.message || 'Grazie! Riceverai un\'email di conferma entro pochi minuti.';
        }
        newsletterForm.reset();
      } catch (error) {
        if (feedback instanceof HTMLElement) {
          feedback.hidden = false;
          const message = error instanceof Error ? error.message : 'Si e\' verificato un problema. Riprova piu\' tardi.';
          feedback.textContent = message;
        }
      }
    });
  })();
</script>
