---
import { siteConfig } from '../lib/config';

interface NavLink {
  label: string;
  href: string;
  children?: { label: string; href: string; icon?: string }[];
}

const navLinks: NavLink[] = [
  { label: 'Home', href: '/' },
  { label: 'Chi Sono', href: '/chi-sono' },
  { label: 'Cosa Faccio', href: '/cosa-faccio' },
  { 
    label: 'Blog', 
    href: '/blog',
    children: [
      { label: 'Tutti gli articoli', href: '/blog', icon: 'articles' },
      { label: 'AudioPillole', href: '/blog/audiopillole', icon: 'audio' },
      { label: 'Podcast', href: '/blog/podcast', icon: 'podcast' },
      { label: 'Rassegna Stampa', href: '/blog/rassegna-stampa', icon: 'press' },
    ]
  },
  { label: 'Eventi', href: '/eventi' },
  { label: 'Contatti', href: '/contatti' },
];

interface Props {
  activePath?: string;
}

const { activePath } = Astro.props;

const isActive = (href: string) => {
  if (!activePath) return false;
  if (href === '/') return activePath === '/';
  return activePath.startsWith(href);
};

const desktopNavHover =
  "relative inline-flex items-center transition-colors duration-200 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-full after:origin-left after:scale-x-0 after:bg-brand-primary after:transition-transform after:duration-200 hover:after:scale-x-100";
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-neutral-border dark:bg-neutral-900/90 dark:border-neutral-800">
  <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/logo_sergio.avif" alt="Logo Sergio Contegiacomo" class="h-12 w-12 rounded-full object-cover flex-shrink-0" />
      <div class="flex flex-col justify-center">
        <span class="text-sm uppercase tracking-[0.3em] text-brand-primary leading-tight">{siteConfig.name}</span>
        <span class="text-xs text-neutral-muted dark:text-neutral-300 leading-tight">{siteConfig.role}</span>
      </div>
    </a>
    <nav aria-label="Principale" class="hidden lg:flex items-center gap-6 text-sm font-medium">
      {navLinks.map((link) => (
        link.children ? (
          <div class="relative group">
            <button
              type="button"
              class={`${desktopNavHover} gap-1 ${isActive(link.href) ? 'text-brand-primary after:scale-x-100' : 'text-neutral-muted dark:text-neutral-300 hover:text-brand-primary'}`}
            >
              {link.label}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <!-- Dropdown -->
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <div class="bg-white dark:bg-neutral-900 rounded-xl shadow-xl border border-neutral-200 dark:border-neutral-800 py-2 min-w-[200px]">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class={`flex items-center gap-3 px-4 py-2.5 text-sm transition hover:bg-brand-primary/10 hover:text-brand-primary ${
                      activePath === child.href ? 'text-brand-primary bg-brand-primary/10' : 'text-neutral-muted dark:text-neutral-300'
                    }`}
                  >
                    {child.icon === 'articles' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                      </svg>
                    )}
                    {child.icon === 'audio' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                      </svg>
                    )}
                    {child.icon === 'podcast' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                      </svg>
                    )}
                    {child.icon === 'press' && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                      </svg>
                    )}
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`${desktopNavHover} ${isActive(link.href) ? 'text-brand-primary after:scale-x-100' : 'text-neutral-muted dark:text-neutral-300 hover:text-brand-primary'}`}
          >
            {link.label}
          </a>
        )
      ))}
      <a
        href="/contatti"
        class="ml-6 inline-flex items-center rounded-full bg-brand-primary px-4 py-2 text-white text-sm font-semibold shadow-md shadow-brand-primary/20 hover:bg-brand-light transition"
      >
        Parliamo
      </a>
    </nav>
    <button
      class="lg:hidden text-brand-primary"
      type="button"
      aria-label="Apri menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-mobile-menu
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<div id="mobile-menu" class="lg:hidden" hidden data-mobile-drawer>
  <div class="fixed inset-0 bg-neutral-text/60 dark:bg-neutral-950/70 z-[60]" data-overlay></div>
  <div class="fixed top-0 right-0 bottom-0 w-4/5 max-w-xs bg-white shadow-xl p-6 flex flex-col gap-6 dark:bg-neutral-900 z-[70]">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="/logo_sergio.avif" alt="Logo Sergio Contegiacomo" class="h-10 w-auto rounded-full" />
        <div>
          <p class="text-sm uppercase tracking-[0.3em] text-brand-primary">{siteConfig.name}</p>
          <p class="text-xs text-neutral-muted dark:text-neutral-300">{siteConfig.role}</p>
        </div>
      </div>
  <button type="button" aria-label="Chiudi menu" data-mobile-close class="text-neutral-muted dark:text-neutral-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <nav class="flex flex-col gap-2 text-base">
      {navLinks.map((link) => (
        link.children ? (
          <div class="border-b border-neutral-border">
            <a
              href={link.href}
              class={`block py-2 transition hover:text-brand-primary ${
                isActive(link.href) ? 'text-brand-primary font-semibold' : 'text-neutral-muted dark:text-neutral-300'
              }`}
            >
              {link.label}
            </a>
            <div class="pl-4 pb-2 space-y-1">
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class={`flex items-center gap-2 py-1.5 text-sm transition hover:text-brand-primary ${
                    activePath === child.href ? 'text-brand-primary' : 'text-neutral-muted/80 dark:text-neutral-400'
                  }`}
                >
                  {child.icon === 'articles' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                  )}
                  {child.icon === 'audio' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                    </svg>
                  )}
                  {child.icon === 'podcast' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                    </svg>
                  )}
                  {child.icon === 'press' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                  )}
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`py-2 transition border-b border-neutral-border hover:text-brand-primary ${
              isActive(link.href) ? 'text-brand-primary font-semibold' : 'text-neutral-muted dark:text-neutral-300'
            }`}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>
    <a
      href="/contatti"
      class="mt-auto inline-flex items-center justify-center rounded-full bg-brand-primary px-4 py-3 text-white font-semibold shadow-md shadow-brand-primary/20 hover:bg-brand-light transition"
    >
      Prenota una call
    </a>
  </div>
</div>

<script is:inline>
  const setupMobileMenu = () => {
    const menuBtn = document.querySelector('[data-mobile-menu]');
    const drawerEl = document.querySelector('[data-mobile-drawer]');
    const closeBtn = document.querySelector('[data-mobile-close]');
    const overlay = drawerEl instanceof HTMLElement ? drawerEl.querySelector('[data-overlay]') : null;

    if (!(menuBtn instanceof HTMLElement) || !(drawerEl instanceof HTMLElement)) return;

    const applyState = (open) => {
      drawerEl.hidden = !open;
      menuBtn.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    };

    menuBtn.addEventListener('click', () => applyState(true));
    closeBtn?.addEventListener('click', () => applyState(false));
    overlay?.addEventListener('click', () => applyState(false));
    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        applyState(false);
      }
    });

    const mediaQuery = window.matchMedia('(min-width: 1024px)');
    const handleMediaChange = (event) => {
      if (event.matches) {
        applyState(false);
      }
    };

    if (typeof mediaQuery.addEventListener === 'function') {
      mediaQuery.addEventListener('change', handleMediaChange);
    } else if (typeof mediaQuery.addListener === 'function') {
      mediaQuery.addListener(handleMediaChange);
    }
  };

  const initThemeToggle = () => {
    const storageKey = 'theme-preference';
    const legacyStorageKey = 'preferred-theme';
    const root = document.documentElement;
    const toggles = document.querySelectorAll('[data-theme-toggle]');

    if (!toggles.length) return;

    const storeTheme = (theme) => {
      try {
        localStorage.setItem(storageKey, theme);
      } catch (error) {
        /* localStorage non disponibile */
      }
    };

    const getStoredTheme = () => {
      try {
        // Clear legacy key so it won't override OS defaults.
        if (localStorage.getItem(legacyStorageKey)) {
          localStorage.removeItem(legacyStorageKey);
        }
        return localStorage.getItem(storageKey);
      } catch (error) {
        return null;
      }
    };

    const getAppliedTheme = () => (root.dataset.theme === 'dark' || root.classList.contains('dark') ? 'dark' : 'light');
    const getPreference = () => {
      const stored = getStoredTheme();
      return stored === 'dark' || stored === 'light' || stored === 'auto' ? stored : 'light';
    };

    const updateIcons = (preference) => {
      toggles.forEach((toggle) => {
        const sun = toggle.querySelector('[data-theme-icon="sun"]');
        const moon = toggle.querySelector('[data-theme-icon="moon"]');
        const auto = toggle.querySelector('[data-theme-icon="auto"]');
        if (sun instanceof HTMLElement) {
          sun.classList.toggle('hidden', preference !== 'light');
        }
        if (moon instanceof HTMLElement) {
          moon.classList.toggle('hidden', preference !== 'dark');
        }
        if (auto instanceof HTMLElement) {
          auto.classList.toggle('hidden', preference !== 'auto');
        }
      });
    };

    const applyAppliedTheme = (theme) => {
      root.classList.toggle('dark', theme === 'dark');
      root.dataset.theme = theme;
    };

    const applyPreference = (preference, persist = true) => {
      if (persist) {
        storeTheme(preference);
      }

      if (preference === 'auto') {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        applyAppliedTheme(prefersDark ? 'dark' : 'light');
      } else {
        applyAppliedTheme(preference);
      }

      updateIcons(preference);
    };

    applyPreference(getPreference(), false);

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const currentPreference = getPreference();

        // Cycle: light -> dark -> auto -> light
        const nextPreference =
          currentPreference === 'light'
            ? 'dark'
            : currentPreference === 'dark'
              ? 'auto'
              : 'light';

        applyPreference(nextPreference, true);
      });
    });

    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    const handlePreferredScheme = (event) => {
      const pref = getPreference();
      if (pref !== 'auto') return;
      // Follow OS preference in auto mode. Do not change the preference.
      applyAppliedTheme(event.matches ? 'dark' : 'light');
      updateIcons('auto');
    };

    if (typeof mediaQuery.addEventListener === 'function') {
      mediaQuery.addEventListener('change', handlePreferredScheme);
    } else if (typeof mediaQuery.addListener === 'function') {
      mediaQuery.addListener(handlePreferredScheme);
    }
  };

  const init = () => {
    setupMobileMenu();
    initThemeToggle();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
