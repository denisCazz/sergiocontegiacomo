---
import { siteConfig } from '../lib/config';

interface NavChild {
  label: string;
  href: string;
  icon: string;
  desc?: string;
}

interface NavGroup {
  heading: string;
  items: NavChild[];
}

interface NavLink {
  label: string;
  href: string;
  mega?: NavGroup[];
}

const contenutiGroups: NavGroup[] = [
  {
    heading: 'Blog',
    items: [
      { label: 'Tutti gli articoli', href: '/blog', icon: 'articles', desc: 'Approfondimenti e analisi' },
      { label: 'AudioPillole', href: '/blog/audiopillole', icon: 'audio', desc: 'Contenuti audio brevi' },
      { label: 'Podcast', href: '/blog/podcast', icon: 'podcast', desc: 'Episodi e interviste' },
      { label: 'Rassegna Stampa', href: '/blog/rassegna-stampa', icon: 'press', desc: 'Articoli e pubblicazioni' },
    ],
  },
  {
    heading: 'Altro',
    items: [
      { label: 'Eventi', href: '/eventi', icon: 'events', desc: 'Calendario appuntamenti' },
      { label: 'Recensioni', href: '/recensioni', icon: 'reviews', desc: 'Cosa dicono i clienti' },
      { label: 'Gallery', href: '/gallery', icon: 'gallery', desc: 'Foto e momenti' },
    ],
  },
];

const navLinks: NavLink[] = [
  { label: 'Home', href: '/' },
  { label: 'Chi Sono', href: '/chi-sono' },
  { label: 'Servizi', href: '/cosa-faccio' },
  { label: 'Contenuti', href: '/blog', mega: contenutiGroups },
  { label: 'Contatti', href: '/contatti' },
];

interface Props {
  activePath?: string;
}

const { activePath } = Astro.props;

const isActive = (href: string) => {
  if (!activePath) return false;
  if (href === '/') return activePath === '/';
  return activePath === href || activePath.startsWith(href + '/');
};

const isExactActive = (href: string) => {
  if (!activePath) return false;
  return activePath === href;
};

const isContenutiActive = () => {
  if (!activePath) return false;
  return contenutiGroups.some(g => g.items.some(i => activePath === i.href || activePath.startsWith(i.href + '/')));
};

const desktopNavHover =
  "relative inline-flex items-center transition-colors duration-200 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-full after:origin-left after:scale-x-0 after:bg-brand-primary after:transition-transform after:duration-200 hover:after:scale-x-100";
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-neutral-border dark:bg-neutral-900/90 dark:border-neutral-800">
  <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <img src="/logo_sergio.avif" alt="Logo Sergio Contegiacomo" width="48" height="48" class="h-12 w-12 rounded-full object-cover flex-shrink-0" />
      <div class="flex flex-col justify-center">
        <span class="text-sm uppercase tracking-[0.3em] text-brand-primary leading-tight">{siteConfig.name}</span>
        <span class="text-xs text-neutral-muted dark:text-neutral-300 leading-tight">{siteConfig.role}</span>
      </div>
    </a>
    <nav aria-label="Principale" class="hidden lg:flex items-center gap-6 text-sm font-medium">
      {navLinks.map((link) => (
        link.mega ? (
          <div class="relative group" data-dropdown>
            <button
              type="button"
              aria-haspopup="true"
              aria-expanded="false"
              class={`${desktopNavHover} gap-1 ${isContenutiActive() ? 'text-brand-primary after:scale-x-100' : 'text-neutral-muted dark:text-neutral-300 hover:text-brand-primary'}`}
              data-dropdown-trigger
            >
              {link.label}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200" data-dropdown-menu role="menu">
              <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-2xl border border-neutral-200 dark:border-neutral-800 p-5 w-[480px]">
                <div class="grid grid-cols-2 gap-6">
                  {link.mega.map((group) => (
                    <div>
                      <p class="text-[11px] font-bold uppercase tracking-wider text-neutral-400 dark:text-neutral-500 mb-3 px-2">{group.heading}</p>
                      <div class="space-y-0.5">
                        {group.items.map((item) => (
                          <a
                            href={item.href}
                            class={`flex items-start gap-3 rounded-lg px-2 py-2 transition hover:bg-brand-primary/5 ${
                              isExactActive(item.href) ? 'bg-brand-primary/5' : ''
                            }`}
                          >
                            <span class={`flex-shrink-0 mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg ${
                              isExactActive(item.href) ? 'bg-brand-primary/15 text-brand-primary' : 'bg-neutral-100 text-neutral-500 dark:bg-neutral-800 dark:text-neutral-400'
                            }`}>
                              {item.icon === 'articles' && (
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                              )}
                              {item.icon === 'audio' && (
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
                              )}
                              {item.icon === 'podcast' && (
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
                              )}
                              {item.icon === 'press' && (
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                              )}
                              {item.icon === 'events' && (
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                              )}
                              {item.icon === 'reviews' && (
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
                              )}
                              {item.icon === 'gallery' && (
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                              )}
                            </span>
                            <div class="min-w-0">
                              <p class={`text-sm font-medium ${isExactActive(item.href) ? 'text-brand-primary' : 'text-neutral-text dark:text-white'}`}>{item.label}</p>
                              {item.desc && <p class="text-xs text-neutral-muted dark:text-neutral-500 mt-0.5">{item.desc}</p>}
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`${desktopNavHover} ${isActive(link.href) ? 'text-brand-primary after:scale-x-100' : 'text-neutral-muted dark:text-neutral-300 hover:text-brand-primary'}`}
          >
            {link.label}
          </a>
        )
      ))}
      <a
        href="/contatti"
        class="ml-6 inline-flex items-center rounded-full bg-brand-primary px-4 py-2 text-white text-sm font-semibold shadow-md shadow-brand-primary/20 hover:bg-brand-light transition"
      >
        Parliamo
      </a>
    </nav>
    <button
      class="lg:hidden text-brand-primary"
      type="button"
      aria-label="Apri menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-mobile-menu
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<div id="mobile-menu" class="lg:hidden" hidden data-mobile-drawer>
  <div class="fixed inset-0 bg-neutral-text/60 dark:bg-neutral-950/70 z-[60]" data-overlay></div>
  <div class="fixed top-0 right-0 bottom-0 w-4/5 max-w-xs bg-white shadow-xl p-6 flex flex-col gap-6 dark:bg-neutral-900 z-[70]">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="/logo_sergio.avif" alt="Logo Sergio Contegiacomo" width="40" height="40" class="h-10 w-10 rounded-full object-cover" />
        <div>
          <p class="text-sm uppercase tracking-[0.3em] text-brand-primary">{siteConfig.name}</p>
          <p class="text-xs text-neutral-muted dark:text-neutral-300">{siteConfig.role}</p>
        </div>
      </div>
  <button type="button" aria-label="Chiudi menu" data-mobile-close class="text-neutral-muted dark:text-neutral-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <nav class="flex flex-col gap-1 text-base overflow-y-auto">
      {navLinks.map((link) => (
        link.mega ? (
          <div class="py-1">
            <p class={`px-1 py-2 text-sm font-semibold ${isContenutiActive() ? 'text-brand-primary' : 'text-neutral-text dark:text-white'}`}>{link.label}</p>
            {link.mega.map((group) => (
              <div class="mb-2">
                <p class="px-1 py-1 text-[11px] font-bold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">{group.heading}</p>
                <div class="space-y-0.5">
                  {group.items.map((item) => (
                    <a
                      href={item.href}
                      class={`flex items-center gap-3 rounded-lg px-2 py-2 text-sm transition hover:bg-brand-primary/5 hover:text-brand-primary ${
                        isExactActive(item.href) ? 'text-brand-primary bg-brand-primary/5 font-medium' : 'text-neutral-muted dark:text-neutral-300'
                      }`}
                    >
                      <span class={`flex-shrink-0 flex h-7 w-7 items-center justify-center rounded-md ${
                        isExactActive(item.href) ? 'bg-brand-primary/15 text-brand-primary' : 'bg-neutral-100 text-neutral-500 dark:bg-neutral-800 dark:text-neutral-400'
                      }`}>
                        {item.icon === 'articles' && <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>}
                        {item.icon === 'audio' && <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>}
                        {item.icon === 'podcast' && <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>}
                        {item.icon === 'press' && <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>}
                        {item.icon === 'events' && <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>}
                        {item.icon === 'reviews' && <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>}
                        {item.icon === 'gallery' && <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>}
                      </span>
                      {item.label}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <a
            href={link.href}
            class={`py-2.5 px-1 transition border-b border-neutral-border/50 hover:text-brand-primary ${
              isActive(link.href) ? 'text-brand-primary font-semibold' : 'text-neutral-muted dark:text-neutral-300'
            }`}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>
    <a
      href="/contatti"
      class="mt-auto inline-flex items-center justify-center rounded-full bg-brand-primary px-4 py-3 text-white font-semibold shadow-md shadow-brand-primary/20 hover:bg-brand-light transition"
    >
      Prenota una call
    </a>
  </div>
</div>

<script is:inline>
  const setupDropdownKeyboard = () => {
    document.querySelectorAll('[data-dropdown]').forEach((dropdown) => {
      const trigger = dropdown.querySelector('[data-dropdown-trigger]');
      const menu = dropdown.querySelector('[data-dropdown-menu]');
      if (!trigger || !menu) return;

      const show = () => {
        menu.classList.remove('opacity-0', 'invisible');
        menu.classList.add('opacity-100', 'visible');
        trigger.setAttribute('aria-expanded', 'true');
      };
      const hide = () => {
        menu.classList.add('opacity-0', 'invisible');
        menu.classList.remove('opacity-100', 'visible');
        trigger.setAttribute('aria-expanded', 'false');
      };

      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
          e.preventDefault();
          show();
          const first = menu.querySelector('a');
          if (first) first.focus();
        }
      });

      menu.addEventListener('keydown', (e) => {
        const items = Array.from(menu.querySelectorAll('a'));
        const idx = items.indexOf(document.activeElement);
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (idx < items.length - 1) items[idx + 1].focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (idx > 0) items[idx - 1].focus();
          else { hide(); trigger.focus(); }
        } else if (e.key === 'Escape') {
          hide();
          trigger.focus();
        }
      });

      dropdown.addEventListener('focusout', (e) => {
        setTimeout(() => {
          if (!dropdown.contains(document.activeElement)) hide();
        }, 0);
      });
    });
  };

  const setupMobileMenu = () => {
    const menuBtn = document.querySelector('[data-mobile-menu]');
    const drawerEl = document.querySelector('[data-mobile-drawer]');
    const closeBtn = document.querySelector('[data-mobile-close]');
    const overlay = drawerEl instanceof HTMLElement ? drawerEl.querySelector('[data-overlay]') : null;

    if (!(menuBtn instanceof HTMLElement) || !(drawerEl instanceof HTMLElement)) return;

    const applyState = (open) => {
      drawerEl.hidden = !open;
      menuBtn.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    };

    menuBtn.addEventListener('click', () => applyState(true));
    closeBtn?.addEventListener('click', () => applyState(false));
    overlay?.addEventListener('click', () => applyState(false));
    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        applyState(false);
      }
    });

    const mediaQuery = window.matchMedia('(min-width: 1024px)');
    const handleMediaChange = (event) => {
      if (event.matches) {
        applyState(false);
      }
    };

    if (typeof mediaQuery.addEventListener === 'function') {
      mediaQuery.addEventListener('change', handleMediaChange);
    } else if (typeof mediaQuery.addListener === 'function') {
      mediaQuery.addListener(handleMediaChange);
    }
  };

  const initThemeToggle = () => {
    const storageKey = 'theme-preference';
    const legacyStorageKey = 'preferred-theme';
    const root = document.documentElement;
    const toggles = document.querySelectorAll('[data-theme-toggle]');

    if (!toggles.length) return;

    const storeTheme = (theme) => {
      try {
        localStorage.setItem(storageKey, theme);
      } catch (error) {
        /* localStorage non disponibile */
      }
    };

    const getStoredTheme = () => {
      try {
        // Clear legacy key so it won't override OS defaults.
        if (localStorage.getItem(legacyStorageKey)) {
          localStorage.removeItem(legacyStorageKey);
        }
        return localStorage.getItem(storageKey);
      } catch (error) {
        return null;
      }
    };

    const getAppliedTheme = () => (root.dataset.theme === 'dark' || root.classList.contains('dark') ? 'dark' : 'light');
    const getPreference = () => {
      const stored = getStoredTheme();
      return stored === 'dark' || stored === 'light' || stored === 'auto' ? stored : 'light';
    };

    const updateIcons = (preference) => {
      toggles.forEach((toggle) => {
        const sun = toggle.querySelector('[data-theme-icon="sun"]');
        const moon = toggle.querySelector('[data-theme-icon="moon"]');
        const auto = toggle.querySelector('[data-theme-icon="auto"]');
        if (sun instanceof HTMLElement) {
          sun.classList.toggle('hidden', preference !== 'light');
        }
        if (moon instanceof HTMLElement) {
          moon.classList.toggle('hidden', preference !== 'dark');
        }
        if (auto instanceof HTMLElement) {
          auto.classList.toggle('hidden', preference !== 'auto');
        }
      });
    };

    const applyAppliedTheme = (theme) => {
      root.classList.toggle('dark', theme === 'dark');
      root.dataset.theme = theme;
    };

    const applyPreference = (preference, persist = true) => {
      if (persist) {
        storeTheme(preference);
      }

      if (preference === 'auto') {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        applyAppliedTheme(prefersDark ? 'dark' : 'light');
      } else {
        applyAppliedTheme(preference);
      }

      updateIcons(preference);
    };

    applyPreference(getPreference(), false);

    toggles.forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const currentPreference = getPreference();

        // Cycle: light -> dark -> auto -> light
        const nextPreference =
          currentPreference === 'light'
            ? 'dark'
            : currentPreference === 'dark'
              ? 'auto'
              : 'light';

        applyPreference(nextPreference, true);
      });
    });

    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    const handlePreferredScheme = (event) => {
      const pref = getPreference();
      if (pref !== 'auto') return;
      // Follow OS preference in auto mode. Do not change the preference.
      applyAppliedTheme(event.matches ? 'dark' : 'light');
      updateIcons('auto');
    };

    if (typeof mediaQuery.addEventListener === 'function') {
      mediaQuery.addEventListener('change', handlePreferredScheme);
    } else if (typeof mediaQuery.addListener === 'function') {
      mediaQuery.addListener(handlePreferredScheme);
    }
  };

  const init = () => {
    setupDropdownKeyboard();
    setupMobileMenu();
    initThemeToggle();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
