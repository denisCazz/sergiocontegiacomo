---
import BaseLayout from '../layouts/BaseLayout.astro';

const googleReviewUrl = 'https://search.google.com/local/writereview?placeid=ChIJxd24-3Sr0hIRmTjD_4K4nEg';
const websiteReviewsUrl = 'https://www.sergiocontegiacomo.it/recensioni';
---

<BaseLayout
  title="Lascia una recensione"
  description="Scegli il canale che preferisci per condividere la tua esperienza con Sergio Contegiacomo."
  keywords="recensione Sergio Contegiacomo, lascia recensione Google, testimonianza consulente patrimoniale"
  activePath="/recensioni"
>
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-dark via-brand-primary to-brand-light py-20 sm:py-24 lg:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.24),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.2),transparent_38%)]"></div>
    <div class="absolute -top-32 -right-24 h-72 w-72 rounded-full bg-white/20 blur-3xl"></div>
    <div class="absolute -bottom-24 -left-20 h-80 w-80 rounded-full bg-amber-300/25 blur-3xl"></div>

    <div class="relative mx-auto max-w-5xl px-6">
      <div class="rounded-3xl border border-white/30 bg-white/95 p-8 shadow-2xl backdrop-blur-xl dark:border-neutral-700 dark:bg-neutral-900/95 sm:p-10 lg:p-14">
        <p class="mb-4 inline-flex rounded-full border border-brand-accent/40 bg-brand-accent/10 px-4 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-brand-dark dark:text-brand-light">
          La tua opinione conta
        </p>
        <h1 class="text-3xl font-serif leading-tight text-neutral-text dark:text-white sm:text-4xl lg:text-5xl">
          Lascia una recensione in meno di un minuto
        </h1>
        <p class="mt-4 max-w-3xl text-base leading-relaxed text-neutral-muted dark:text-neutral-300 sm:text-lg">
          Grazie per la fiducia: il tuo feedback aiuta altre persone a scegliere con maggiore serenita'. Scegli il canale che preferisci qui sotto.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          <a
            href={googleReviewUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex min-h-[144px] flex-col justify-between rounded-2xl border border-neutral-border bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 dark:border-neutral-700 dark:bg-neutral-800"
            aria-label="Lascia una recensione su Google"
          >
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
              </svg>
              <span class="text-xl font-semibold text-neutral-text dark:text-white">Recensione su Google</span>
            </div>
            <p class="mt-3 text-sm text-neutral-muted dark:text-neutral-300">
              Ideale se hai gia' un account Google.
            </p>
            <span class="mt-4 inline-flex items-center text-sm font-semibold text-brand-primary transition group-hover:text-brand-dark dark:group-hover:text-brand-light">
              Apri Google
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-1.5 h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a1 1 0 011-1h9.586L10.293 5.707a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 01-1-1z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>

          <a
            href={websiteReviewsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex min-h-[144px] flex-col justify-between rounded-2xl border border-neutral-border bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-brand-primary hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 dark:border-neutral-700 dark:bg-neutral-800"
            aria-label="Lascia una testimonianza sul sito"
          >
            <div class="flex items-center gap-3">
              <div class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-brand-primary/15 text-brand-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M4 3a2 2 0 00-2 2v14l4-3h14a2 2 0 002-2V5a2 2 0 00-2-2H4z" />
                </svg>
              </div>
              <span class="text-xl font-semibold text-neutral-text dark:text-white">Testimonianza sul sito</span>
            </div>
            <p class="mt-3 text-sm text-neutral-muted dark:text-neutral-300">
              Compila il form recensioni sul sito ufficiale.
            </p>
            <span class="mt-4 inline-flex items-center text-sm font-semibold text-brand-primary transition group-hover:text-brand-dark dark:group-hover:text-brand-light">
              Apri il form
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-1.5 h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a1 1 0 011-1h9.586L10.293 5.707a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 01-1-1z" clip-rule="evenodd" />
              </svg>
            </span>
          </a>
        </div>

        <p class="mt-8 text-sm text-neutral-muted dark:text-neutral-400">
          Entrambi i pulsanti aprono il canale selezionato in una nuova scheda.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
