---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTASection from '../components/CTASection.astro';

const skills = [
  "Pianificazione patrimoniale olistica",
  "Coordinamento di team multidisciplinari",
  "Analisi di rischi e opportunita' per patrimoni complessi",
  "Formazione e coaching decisionale",
];
---

<BaseLayout 
  title="Chi Sono" 
  description="Sergio Contegiacomo: oltre 15 anni di esperienza nel private banking e wealth management. Coach finanziario certificato, formazione SDA Bocconi, iscritto ANASF."
  keywords="Sergio Contegiacomo biografia, consulente patrimoniale esperienza, coach finanziario certificato, SDA Bocconi, wealth planner Italia"
  activePath="/chi-sono"
>
  <section class="relative py-24 lg:py-32 bg-white dark:bg-neutral-950 overflow-hidden">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-96 h-96 bg-brand-accent/5 rounded-full blur-3xl"></div>
    
    <div class="relative mx-auto max-w-6xl px-6">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center mb-32">
        <div class="space-y-10">
          <div class="inline-flex items-center gap-2 rounded-full bg-brand-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary dark:bg-brand-primary/20 dark:text-brand-light">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
            Chi Sono
          </div>
          <h1 class="text-5xl md:text-7xl font-serif font-medium text-neutral-text leading-[1.1] dark:text-white tracking-tight">
            Una guida che unisce <br/> <span class="text-brand-primary italic">consulenza</span> e <span class="text-brand-primary italic">coaching</span>.
          </h1>
          <p class="text-xl text-neutral-muted leading-relaxed dark:text-neutral-300 max-w-lg">
            Dopo oltre quindici anni nel private banking e nel wealth management per famiglie imprenditoriali, ho scelto di costruire un modello indipendente che integra finanza, governance e comportamenti decisionali.
          </p>
        </div>
        <div class="relative lg:pl-12">
          <div class="aspect-[4/5] rounded-[2.5rem] overflow-hidden shadow-2xl shadow-brand-primary/10 rotate-2 hover:rotate-0 transition duration-700 ease-out">
            <img
              src="/sergio_2.jpg"
              alt="Sergio Contegiacomo durante una sessione di lavoro"
              loading="lazy"
              class="w-full h-full object-cover transform hover:scale-105 transition duration-700"
            />
          </div>
        </div>
      </div>

      <div class="grid gap-8 lg:gap-12 lg:grid-cols-12 items-start mb-12">
        <div class="lg:col-span-7 rounded-3xl md:rounded-[2.5rem] border border-neutral-border bg-white p-6 md:p-10 lg:p-12 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
          <h3 class="text-xs uppercase tracking-[0.3em] text-brand-primary dark:text-brand-light mb-6 md:mb-8 font-bold">Il mio Percorso</h3>
          <div class="prose prose-lg prose-neutral dark:prose-invert max-w-none">
            <p class="text-lg md:text-xl leading-relaxed text-neutral-800 dark:text-neutral-100 font-medium">
              Ho lavorato in realtà internazionali, seguendo patrimoni familiari e manageriali, coordinando private banker, fiscalisti e consulenti legali. Oggi metto a disposizione questa esperienza in maniera indipendente, affiancando imprenditori e famiglie nei momenti strategici.
            </p>
            <p class="text-neutral-600 dark:text-neutral-400 mt-6 leading-relaxed text-base md:text-lg">
              La mia missione è facilitare scelte consapevoli: trasformare numeri e scenari in decisioni condivise, con un metodo replicabile che mette al centro la persona e i suoi obiettivi di vita.
            </p>
          </div>
        </div>

        <div class="lg:col-span-5 space-y-6 md:space-y-8">
          <div class="rounded-3xl md:rounded-[2.5rem] border border-neutral-border bg-neutral-50 p-6 md:p-10 dark:border-neutral-800 dark:bg-neutral-900/50 h-full">
            <h3 class="text-xs uppercase tracking-[0.3em] text-brand-primary dark:text-brand-light mb-6 font-bold">Le mie Certificazioni</h3>
            <ul class="space-y-4 md:space-y-5">
              <li class="flex items-start gap-4 text-neutral-700 dark:text-neutral-300">
                <div class="h-2.5 w-2.5 rounded-full bg-brand-accent shrink-0 mt-2"></div>
                <span class="text-base md:text-lg">SDA BOCCONI</span>
              </li>
            </ul>
            
            <h3 class="text-xs uppercase tracking-[0.3em] text-brand-primary dark:text-brand-light mt-8 mb-6 font-bold">Altri Corsi e Certificazioni</h3>
            <ul class="space-y-4 md:space-y-5">
              <li class="flex items-start gap-4 text-neutral-700 dark:text-neutral-300">
                <div class="h-2.5 w-2.5 rounded-full bg-brand-accent shrink-0 mt-2"></div>
                <span class="text-base md:text-lg">Abilitazione di educatore finanziario presso l'Anasf - 2013</span>
              </li>
              <li class="flex items-start gap-4 text-neutral-700 dark:text-neutral-300">
                <div class="h-2.5 w-2.5 rounded-full bg-brand-accent shrink-0 mt-2"></div>
                <span class="text-base md:text-lg">Abilitazione di Coach - Istituto universitario di Scienze della mediazione Linguistica di Varese - 2011</span>
              </li>
              <li class="flex items-start gap-4 text-neutral-700 dark:text-neutral-300">
                <div class="h-2.5 w-2.5 rounded-full bg-brand-accent shrink-0 mt-2"></div>
                <span class="text-base md:text-lg">Certificazione di Wealth Planner dell'università Cattolica di Milano - 2005</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="rounded-3xl md:rounded-[2.5rem] bg-gradient-to-br from-brand-primary to-brand-dark p-8 md:p-12 lg:p-16 text-white shadow-xl shadow-brand-primary/20 relative overflow-hidden">
        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
        
        <div class="relative z-10 grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
              </div>
              <h3 class="text-xl md:text-2xl font-bold uppercase tracking-widest text-white">Il mio Metodo</h3>
            </div>
            
            <p class="text-white/90 text-lg md:text-xl leading-relaxed font-light">
              Analisi quantitative, ascolto attivo e coaching. Ogni percorso inizia con una diagnosi patrimoniale approfondita per costruire una strategia su misura per te.
            </p>
          </div>
          
          <div class="bg-white/10 rounded-3xl p-8 backdrop-blur-sm border border-white/10">
            <ul class="space-y-6">
              {skills.map((skill) => (
                <li class="flex items-start gap-4 group">
                  <div class="mt-1 w-6 h-6 rounded-full bg-brand-accent flex items-center justify-center shrink-0 shadow-lg shadow-brand-accent/30 group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-dark" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="text-lg font-medium text-white group-hover:text-brand-accent transition-colors">{skill}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Ti accompagno nel prendere decisioni patrimoniali lucide"
    description="Definiamo insieme i tuoi obiettivi e creiamo un framework di governance che ti permetta di agire con chiarezza e controllo."
    primaryCta={{ label: 'Prenota una consulenza', href: '/contatti' }}
    secondaryCta={{ label: 'Richiedi il profilo completo', href: '/contatti?richiedi=profilo' }}
  />
</BaseLayout>
