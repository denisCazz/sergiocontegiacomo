---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTASection from '../components/CTASection.astro';

export const prerender = true;

const skills = [
  "Analisi situazione socio-economica personale/familiare",
  "Analisi rischi \"invisibili\"",
  "Identificazione bisogni palesi e latenti + definizione obiettivi",
  "Associazione risorse a bisogni e obiettivi",
  "Verifica efficacia ed efficienza soluzioni in essere",
  "Proposta Strategia migliorativa",
];

const certificazioni = [
  {
    anno: "1987",
    titolo: "Diploma di ragioniere e perito commerciale",
    ente: "Istituto Tecnico Commerciale e per Geometri Luigi Einaudi di Alba (Cn)",
  },
  {
    anno: "1993",
    titolo: "Iscrizione Albo Consulenti Finanziari",
    ente: "Delibera Consob n. 7415 del 28/09/1993",
  },
  {
    anno: "2004",
    titolo: "Certificazione Wealth Planner",
    ente: "Università Cattolica di Milano",
  },
  {
    anno: "2011",
    titolo: "Abilitazione di Coach",
    ente: "Istituto Universitario di Scienze della Mediazione Linguistica di Varese – 1° Master di Alta Formazione Universitaria in Coaching",
  },
  {
    anno: "2013",
    titolo: "Abilitazione Educatore/Formatore finanziario",
    ente: "ANASF – Associazione Nazionale Consulenti Finanziari",
  },
];

const teamwork = [
  {
    nome: "Simone Contegiacomo",
    ruolo: "Consulente Assicurativo",
    descrizione: "Consulente assicurativo di nuova generazione, specializzato in soluzioni digitali e pianificazione patrimoniale per giovani professionisti e famiglie.",
    link: "https://simonecontegiacomo.it",
  },
  {
    nome: "Avv. Prof. Andrea Ballancin",
    ruolo: "Avvocato, Dottore Commercialista e Professore di Diritto Tributario",
    descrizione: "Socio equity MBA Tax. Professore Associato di Diritto Tributario presso l'Università del Piemonte Orientale. Laurea in Economia (Bocconi) e Giurisprudenza (Milano-Bicocca) con lode. Master LL.M. in International Taxation (Leiden). Dottore di Ricerca in Diritto Tributario. Autore di saggi in materia tributaria.",
    link: "https://www.mba-tax.it/team/avvocato-andrea-ballancin/",
  },
  {
    nome: "Prof. Alessandro Ciatti",
    ruolo: "Professore Ordinario di Diritto Privato",
    descrizione: "Ordinario di Diritto Privato all'Università di Torino. Avvocato e Dottore di ricerca in Diritto Privato (Pisa). Insegna Istituzioni di Diritto Privato, Diritto Civile e Diritto Privato Europeo. Membro della redazione di Contratto e Impresa/Europa e Giurisprudenza Italiana. Autore di numerose pubblicazioni in materia civilistica.",
    link: "https://www.civilistiitaliani.eu/soci/soci-effettivi/221-ciatti-alessandro",
  },
];
---

<BaseLayout 
  title="Chi Sono" 
  description="Sergio Contegiacomo: oltre 15 anni di esperienza nel private banking e wealth management. Coach finanziario certificato, formazione SDA Bocconi, iscritto ANASF."
  keywords="Sergio Contegiacomo biografia, consulente patrimoniale esperienza, coach finanziario certificato, SDA Bocconi, wealth planner Italia"
  activePath="/chi-sono"
>
  <section class="relative py-24 lg:py-32 bg-white dark:bg-neutral-950 overflow-hidden">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-96 h-96 bg-brand-accent/5 rounded-full blur-3xl"></div>
    
    <div class="relative mx-auto max-w-6xl px-6">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center mb-32">
        <div class="space-y-10">
          <div class="inline-flex items-center gap-2 rounded-full bg-brand-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary dark:bg-brand-primary/20 dark:text-brand-light">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
            Chi Sono
          </div>
          <h1 class="text-5xl md:text-7xl font-serif font-medium text-neutral-text leading-[1.1] dark:text-white tracking-tight">
            L'Architetto delle Tue <br/> <span class="text-brand-primary italic">giuste scelte patrimoniali</span>.
          </h1>
          <p class="text-xl text-neutral-muted leading-relaxed dark:text-neutral-300 max-w-lg">
            Nel cervello umano, secondo Daniel Kahneman, Premio Nobel per l'Economia 2002, esistono oltre 150 trappole mentali (bias) che portano a decisioni finanziarie irrazionali, sbagliate, inefficaci e perdenti. Le trappole mentali sono "virus", schemi di pensiero automatici distorti e ripetitivi. Riconoscerle è cruciale per migliorare la gestione dei propri risparmi e investimenti.
          </p>
        </div>
        <div class="relative lg:pl-12">
          <div class="aspect-[4/5] rounded-[2.5rem] overflow-hidden shadow-2xl shadow-brand-primary/10 rotate-2 hover:rotate-0 transition duration-700 ease-out">
            <img
              src="/sergio_2.avif"
              alt="Sergio Contegiacomo durante una sessione di lavoro"
              loading="lazy"
              class="w-full h-full object-cover transform hover:scale-105 transition duration-700"
            />
          </div>
        </div>
      </div>

      <div class="grid gap-8 lg:gap-12 lg:grid-cols-12 items-start mb-12">
        <div class="lg:col-span-7 rounded-3xl md:rounded-[2.5rem] border border-neutral-border bg-white p-6 md:p-10 lg:p-12 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
          <h3 class="text-xs uppercase tracking-[0.3em] text-brand-primary dark:text-brand-light mb-6 md:mb-8 font-bold">Il mio Percorso</h3>
          <div class="prose prose-lg prose-neutral dark:prose-invert max-w-none">
            <p class="text-lg md:text-xl leading-relaxed text-neutral-800 dark:text-neutral-100 font-medium">
              Da oltre 35 anni nel Private Banking e nel Wealth Management mi occupo di risparmio, investimenti, patrimoni e ricchezza. Assisto famiglie e aziende nella gestione integrata di tutto il loro patrimonio, affiancato e coadiuvato dai migliori commercialisti, legali e fiscalisti italiani.
            </p>
            <blockquote class="border-l-4 border-brand-primary pl-6 my-6 italic text-neutral-600 dark:text-neutral-400">
              "Il sapere vero non sta soltanto nel sapere, ma nel sapere dove sta il vero sapere."
              <footer class="text-sm font-semibold text-brand-primary mt-2">— Sergio Contegiacomo</footer>
            </blockquote>
            <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed text-base md:text-lg">
              La mia missione è facilitare scelte giuste, consapevoli e lungimiranti con un metodo replicabile che mette sempre al centro la persona con i suoi valori ed i suoi progetti di vita.
            </p>
          </div>
        </div>

        <div class="lg:col-span-5 space-y-6 md:space-y-8">
          <div class="rounded-3xl md:rounded-[2.5rem] border border-neutral-border bg-neutral-50 p-6 md:p-10 dark:border-neutral-800 dark:bg-neutral-900/50 h-full">
            <h3 class="text-xs uppercase tracking-[0.3em] text-brand-primary dark:text-brand-light mb-6 font-bold">Le mie Certificazioni</h3>
            <ul class="space-y-5">
              {certificazioni.map((cert) => (
                <li class="flex items-start gap-4 text-neutral-700 dark:text-neutral-300">
                  <div class="shrink-0 w-14 text-sm font-bold text-brand-primary">{cert.anno}</div>
                  <div>
                    <span class="block font-semibold text-neutral-800 dark:text-white">{cert.titolo}</span>
                    <span class="text-sm text-neutral-500 dark:text-neutral-400">{cert.ente}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <div class="rounded-3xl md:rounded-[2.5rem] bg-gradient-to-br from-brand-primary to-brand-dark p-8 md:p-12 lg:p-16 text-white shadow-xl shadow-brand-primary/20 relative overflow-hidden">
        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
        
        <div class="relative z-10 grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
              </div>
              <h3 class="text-xl md:text-2xl font-bold uppercase tracking-widest text-white">Il mio Metodo</h3>
            </div>
            
            <p class="text-white/90 text-lg md:text-xl leading-relaxed font-light">
              Analisi quantitative, ascolto attivo e coaching. Ogni percorso inizia con una diagnosi patrimoniale approfondita per costruire una strategia su misura per te.
            </p>
          </div>
          
          <div class="bg-white/10 rounded-3xl p-8 backdrop-blur-sm border border-white/10">
            <ul class="space-y-5">
              {skills.map((skill, i) => (
                <li class="flex items-start gap-4 group">
                  <div class="mt-0.5 w-7 h-7 rounded-full bg-brand-accent flex items-center justify-center shrink-0 shadow-lg shadow-brand-accent/30 group-hover:scale-110 transition-transform text-brand-dark font-bold text-sm">
                    {i + 1}
                  </div>
                  <span class="text-base font-medium text-white group-hover:text-brand-accent transition-colors">{skill}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEZIONE IL MIO TEAMWORK -->
  <section class="py-24 lg:py-32 bg-neutral-50 dark:bg-neutral-900">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-brand-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary dark:bg-brand-primary/20 dark:text-brand-light mb-4">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
          Il Mio Teamwork
        </div>
        <h2 class="text-3xl md:text-5xl font-serif font-medium text-neutral-text dark:text-white mb-4">Professionisti al tuo fianco</h2>
        <p class="text-lg text-neutral-muted dark:text-neutral-300 max-w-2xl mx-auto">
          Collaboro stabilmente con i migliori commercialisti, legali e fiscalisti italiani per offrirti una consulenza integrata a 360 gradi.
        </p>
      </div>
      
      <div class="grid gap-8 md:grid-cols-3">
        {teamwork.map((member) => (
          <div class="rounded-3xl border border-neutral-border bg-white p-8 shadow-sm hover:shadow-card hover:-translate-y-1 transition duration-300 dark:border-neutral-800 dark:bg-neutral-950">
            <div class="w-16 h-16 rounded-full bg-brand-primary/10 flex items-center justify-center text-brand-primary text-2xl font-bold mb-6">
              {member.nome.charAt(0)}
            </div>
            <h3 class="text-xl font-semibold text-neutral-text dark:text-white mb-1">{member.nome}</h3>
            <p class="text-sm text-brand-primary font-medium mb-4">{member.ruolo}</p>
            <p class="text-neutral-muted text-sm leading-relaxed mb-6 dark:text-neutral-300">{member.descrizione}</p>
            {member.link && (
              <a href={member.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-primary hover:text-brand-light transition">
                Visita il sito
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Ti accompagno nel prendere le decisioni giuste per te"
    description="Definiamo insieme i tuoi obiettivi e creiamo un framework di governance che ti permetta di agire con chiarezza e controllo."
    primaryCta={{ label: 'Prenota una consulenza', href: '/contatti' }}
    secondaryCta={{ label: 'Richiedi il profilo completo', href: '/contatti?richiedi=profilo' }}
  />
</BaseLayout>
