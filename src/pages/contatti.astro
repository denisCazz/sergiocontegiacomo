---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { siteConfig } from '../lib/config';

export const prerender = true;

const contactChannels = [
  {
    label: 'Email',
    value: siteConfig.contactEmail,
    href: `mailto:${siteConfig.contactEmail}`,
  },
  {
    label: 'Telefono',
    value: siteConfig.phone,
    href: `tel:${siteConfig.phone.replace(/\s+/g, '')}`,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/sergiocontegiacomo',
    href: siteConfig.social.linkedin,
  },
];
---

<BaseLayout 
  title="Contatti" 
  description="Contatta Sergio Contegiacomo per una consulenza patrimoniale. Studio a Bra (Cuneo), Piazza Roma 39. Prenota una call o richiedi informazioni."
  keywords="contatti Sergio Contegiacomo, consulente patrimoniale Bra, appuntamento consulenza finanziaria, telefono, email"
  activePath="/contatti"
>
  <!-- Hero compatto -->
  <section class="relative py-16 lg:py-20 bg-gradient-to-b from-brand-primary/5 to-neutral-base dark:from-brand-primary/10 dark:to-neutral-950 overflow-hidden">
    <div class="absolute top-0 right-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6 relative z-10">
      <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary shadow-sm dark:bg-neutral-900 dark:text-brand-light border border-neutral-100 dark:border-neutral-800 mb-4">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
            Contatti
          </div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif font-medium text-neutral-text dark:text-white leading-tight mb-4">
            Parliamo del tuo <span class="text-brand-primary italic">progetto</span>
          </h1>
          <p class="text-lg text-neutral-muted leading-relaxed dark:text-neutral-300">
            Compila il modulo o contattami direttamente per una consulenza personalizzata.
          </p>
        </div>
        
        <!-- Quick actions -->
        <div class="flex flex-wrap gap-3">
          <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="inline-flex items-center gap-2 rounded-full bg-brand-primary px-6 py-3 text-white font-semibold shadow-lg shadow-brand-primary/30 hover:bg-brand-light hover:scale-105 transition duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {siteConfig.phone}
          </a>
          <a 
            href={siteConfig.social.linkedin} 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-[#0A66C2] px-6 py-3 text-white font-semibold hover:bg-[#004182] transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Seguimi
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12 lg:py-20 bg-neutral-base dark:bg-neutral-950">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        
        <!-- Colonna Form -->
        <div class="order-2 lg:order-1">
          <form class="rounded-3xl border border-neutral-border bg-white p-6 md:p-8 shadow-xl shadow-neutral-200/50 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-none" data-contact-form>
            <h3 class="text-2xl font-serif text-neutral-900 dark:text-white mb-6">Invia un messaggio</h3>
            
            <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 mb-4">
              <div class="space-y-2">
                <label class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Nome *</label>
                <input
                  type="text"
                  name="nome"
                  required
                  class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-base focus:border-brand-primary focus:bg-white focus:ring-2 focus:ring-brand-primary/20 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white"
                  placeholder="Mario"
                />
              </div>
              <div class="space-y-2">
                <label class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Cognome *</label>
                <input
                  type="text"
                  name="cognome"
                  required
                  class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-base focus:border-brand-primary focus:bg-white focus:ring-2 focus:ring-brand-primary/20 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white"
                  placeholder="Rossi"
                />
              </div>
            </div>

            <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 mb-4">
              <div class="space-y-2">
                <label class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Email *</label>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-base focus:border-brand-primary focus:bg-white focus:ring-2 focus:ring-brand-primary/20 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white"
                  placeholder="mario@esempio.com"
                />
              </div>
              <div class="space-y-2">
                <label class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Telefono</label>
                <input
                  type="tel"
                  name="telefono"
                  class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-base focus:border-brand-primary focus:bg-white focus:ring-2 focus:ring-brand-primary/20 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white"
                  placeholder="+39 ..."
                />
              </div>
            </div>

            <div class="space-y-2 mb-6">
              <label class="text-sm font-medium text-neutral-700 dark:text-neutral-300">Messaggio</label>
              <textarea
                name="messaggio"
                rows="4"
                class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-base focus:border-brand-primary focus:bg-white focus:ring-2 focus:ring-brand-primary/20 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white resize-none"
                placeholder="Come posso aiutarti?"
              ></textarea>
            </div>

            <div class="flex items-start gap-3 mb-6">
              <input
                id="privacy"
                name="privacy"
                type="checkbox"
                required
                class="mt-1 h-4 w-4 rounded border-neutral-300 text-brand-primary focus:ring-brand-primary dark:border-neutral-700 dark:bg-neutral-800"
              />
              <label for="privacy" class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">
                Ho letto e accetto l'<a href="/privacy" class="text-brand-primary hover:underline">informativa sulla privacy</a> e acconsento al trattamento dei miei dati personali.
              </label>
            </div>

            <button
              type="submit"
              class="w-full inline-flex items-center justify-center rounded-xl bg-brand-primary px-6 py-4 text-base font-semibold text-white shadow-lg shadow-brand-primary/20 hover:bg-brand-light transition duration-300"
            >
              Invia messaggio
            </button>
            
            <div class="mt-4 text-center">
              <p class="text-sm font-medium text-green-600 dark:text-green-400" data-success-message hidden>
                Grazie per il messaggio. Ti risponderò entro 24 ore.
              </p>
              <p class="text-sm font-medium text-red-600 dark:text-red-400" data-error-message hidden>
                Si è verificato un errore. Riprova più tardi.
              </p>
            </div>
          </form>
        </div>
        
        <!-- Colonna Info -->
        <div class="order-1 lg:order-2 space-y-6">
          <!-- Contatti rapidi -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href={`mailto:${siteConfig.contactEmail}`} class="group flex items-center gap-4 rounded-2xl border border-neutral-200 bg-white p-4 hover:border-brand-primary/50 hover:shadow-lg transition-all dark:border-neutral-800 dark:bg-neutral-900">
              <div class="h-12 w-12 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-xs text-neutral-500 dark:text-neutral-400 mb-0.5">Email</p>
                <p class="text-sm font-medium text-neutral-900 dark:text-white truncate">{siteConfig.contactEmail}</p>
              </div>
            </a>
            
            <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="group flex items-center gap-4 rounded-2xl border border-neutral-200 bg-white p-4 hover:border-brand-primary/50 hover:shadow-lg transition-all dark:border-neutral-800 dark:bg-neutral-900">
              <div class="h-12 w-12 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-xs text-neutral-500 dark:text-neutral-400 mb-0.5">Telefono</p>
                <p class="text-sm font-semibold text-brand-primary">{siteConfig.phone}</p>
              </div>
            </a>
          </div>
          
          <!-- Mappa e indirizzo -->
          <div class="rounded-2xl border border-neutral-200 bg-white overflow-hidden dark:border-neutral-800 dark:bg-neutral-900">
            <div class="aspect-[16/9] w-full">
              <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2820.744668892!2d7.8494!3d44.6988!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12d2b3e8b8b8b8b8%3A0x0!2sPiazza%20Roma%2C%2039%2C%2012042%20Bra%20CN!5e0!3m2!1sit!2sit!4v1702656000000!5m2!1sit!2sit"
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade"
                class="w-full h-full"
                title="Mappa dello studio di Sergio Contegiacomo a Bra"
              ></iframe>
            </div>
            <div class="p-4 flex items-center justify-between gap-4">
              <div>
                <p class="font-medium text-neutral-900 dark:text-white">{siteConfig.address}</p>
                <p class="text-sm text-neutral-500 dark:text-neutral-400">Ricevo su appuntamento</p>
              </div>
              <a 
                href="https://www.google.com/maps/dir//Piazza+Roma,+39,+12042+Bra+CN" 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex-shrink-0 inline-flex items-center gap-2 rounded-xl bg-neutral-100 px-4 py-2 text-sm font-medium text-neutral-700 hover:bg-brand-primary hover:text-white transition dark:bg-neutral-800 dark:text-neutral-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
                Indicazioni
              </a>
            </div>
          </div>
          
          <!-- Orari -->
          <div class="rounded-2xl border border-neutral-200 bg-white p-5 dark:border-neutral-800 dark:bg-neutral-900">
            <h3 class="text-sm font-semibold text-neutral-900 dark:text-white mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Orari di ricevimento
            </h3>
            <ul class="space-y-2 text-sm">
              <li class="flex justify-between py-1.5 border-b border-neutral-100 dark:border-neutral-800">
                <span class="text-neutral-500">Lunedì</span>
                <span class="font-medium text-neutral-700 dark:text-neutral-300">08:30–13:00 · 18:00–20:00</span>
              </li>
              <li class="flex justify-between py-1.5 border-b border-neutral-100 dark:border-neutral-800">
                <span class="text-neutral-500">Martedì</span>
                <span class="font-medium text-neutral-700 dark:text-neutral-300">08:30–13:00</span>
              </li>
              <li class="flex justify-between py-1.5 border-b border-neutral-100 dark:border-neutral-800">
                <span class="text-neutral-500">Mercoledì</span>
                <span class="font-medium text-neutral-700 dark:text-neutral-300">08:30–13:00 · 18:00–20:00</span>
              </li>
              <li class="flex justify-between py-1.5 border-b border-neutral-100 dark:border-neutral-800">
                <span class="text-neutral-500">Giovedì</span>
                <span class="font-medium text-neutral-700 dark:text-neutral-300">08:30–12:00 · 14:00–18:00</span>
              </li>
              <li class="flex justify-between py-1.5 border-b border-neutral-100 dark:border-neutral-800">
                <span class="text-neutral-500">Venerdì</span>
                <span class="font-medium text-neutral-700 dark:text-neutral-300">08:30–13:00</span>
              </li>
              <li class="flex justify-between py-1.5">
                <span class="text-neutral-500">Sabato – Domenica</span>
                <span class="text-neutral-400 italic">Chiuso</span>
              </li>
            </ul>
          </div>
          
          <!-- Download brochure -->
          <a href="/brochure.pdf" download class="group flex items-center gap-4 rounded-2xl bg-gradient-to-r from-brand-primary to-brand-primary/80 p-5 text-white hover:shadow-xl hover:shadow-brand-primary/20 transition-all">
            <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold">Scarica la presentazione</p>
              <p class="text-sm text-white/70">PDF con servizi e metodo di lavoro</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-50 group-hover:opacity-100 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const contactForm = document.querySelector('[data-contact-form]');
    const successMsg = document.querySelector('[data-success-message]');
    const errorMsg = document.querySelector('[data-error-message]');

    contactForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!(contactForm instanceof HTMLFormElement)) return;

      const submitBtn = contactForm.querySelector('button[type="submit"]');
      const originalBtnText = submitBtn?.textContent ?? '';
      if (submitBtn instanceof HTMLButtonElement) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Invio in corso...';
      }

      const data = Object.fromEntries(new FormData(contactForm));

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const json = await res.json().catch(() => ({}));
        if (!res.ok) {
          throw new Error(json?.message || 'Request failed');
        }

        if (successMsg instanceof HTMLElement) successMsg.hidden = false;
        if (errorMsg instanceof HTMLElement) errorMsg.hidden = true;
        contactForm.reset();
      } catch (error) {
        if (errorMsg instanceof HTMLElement) {
          errorMsg.hidden = false;
          const message = error instanceof Error ? error.message : 'Errore inatteso';
          errorMsg.textContent = message || 'Si è verificato un errore. Riprova più tardi.';
        }
        if (successMsg instanceof HTMLElement) successMsg.hidden = true;
      } finally {
        if (submitBtn instanceof HTMLButtonElement) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
        }
      }
    });
  })();
</script>
