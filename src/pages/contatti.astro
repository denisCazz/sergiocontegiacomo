---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { siteConfig } from '../lib/config';

const contactChannels = [
  {
    label: 'Email',
    value: siteConfig.contactEmail,
    href: `mailto:${siteConfig.contactEmail}`,
  },
  {
    label: 'Telefono',
    value: siteConfig.phone,
    href: `tel:${siteConfig.phone.replace(/\s+/g, '')}`,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/sergiocontegiacomo',
    href: siteConfig.social.linkedin,
  },
];
---

<BaseLayout 
  title="Contatti" 
  description="Contatta Sergio Contegiacomo per una consulenza patrimoniale. Studio a Bra (Cuneo), Piazza Roma 39. Prenota una call o richiedi informazioni."
  keywords="contatti Sergio Contegiacomo, consulente patrimoniale Bra, appuntamento consulenza finanziaria, telefono, email"
  activePath="/contatti"
>
  <section class="relative py-24 lg:py-32 bg-neutral-base dark:bg-neutral-950 overflow-hidden">
    <div class="absolute top-0 right-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6">
      <div class="max-w-4xl mx-auto text-center mb-16 md:mb-24 space-y-6 md:space-y-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary shadow-sm dark:bg-neutral-900 dark:text-brand-light border border-neutral-100 dark:border-neutral-800">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
          Contatti
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-serif font-medium text-neutral-text dark:text-white leading-[1.1] tracking-tight">
          Parliamo del tuo <br/> <span class="text-brand-primary italic">progetto patrimoniale</span>
        </h1>
        <p class="text-lg md:text-xl lg:text-2xl text-neutral-muted leading-relaxed dark:text-neutral-300 max-w-2xl mx-auto font-light">
          Compila il modulo oppure prenota una call introduttiva. Valuteremo insieme il percorso più adatto e i prossimi passi concreti.
        </p>
        
        <div class="pt-4">
          <a href={`tel:${siteConfig.phone.replace(/\s+/g, '')}`} class="inline-flex items-center gap-2 rounded-full bg-brand-primary px-8 py-4 text-white text-lg font-semibold shadow-lg shadow-brand-primary/30 hover:bg-brand-light hover:scale-105 transition duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Chiamami ora
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-20 items-start">
        <div class="lg:col-span-5 space-y-6 md:space-y-10">
          <div class="rounded-3xl md:rounded-[2.5rem] border border-neutral-border bg-white p-5 md:p-10 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
            <h3 class="text-xs uppercase tracking-[0.3em] text-brand-primary dark:text-brand-light mb-6 md:mb-8 font-bold">Studio</h3>
            <div class="space-y-4">
              <p class="text-xl md:text-2xl text-neutral-text dark:text-neutral-100 font-serif">
                {siteConfig.address}
              </p>
              <p class="text-neutral-600 dark:text-neutral-400 text-base md:text-lg">
                Ricevo su appuntamento presso il mio studio o in video call.
              </p>
            </div>
            <hr class="my-8 md:my-10 border-neutral-100 dark:border-neutral-800" />
            <div class="space-y-6 md:space-y-8">
              {contactChannels.map((channel) => (
                <a href={channel.href} class="flex items-start gap-4 md:gap-5 group">
                  <div class="h-10 w-10 md:h-12 md:w-12 rounded-full bg-neutral-50 flex items-center justify-center text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition duration-300 dark:bg-neutral-800 dark:text-brand-light shadow-sm flex-shrink-0 mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                  </div>
                  <div class="min-w-0 pt-1">
                    <p class="text-xs uppercase tracking-wider text-neutral-500 dark:text-neutral-400 mb-1">{channel.label}</p>
                    <p class={`text-base md:text-lg break-words ${channel.label === 'Telefono' ? 'text-brand-primary font-bold text-xl' : 'text-neutral-900 font-medium dark:text-white'}`}>{channel.value}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <div class="rounded-3xl md:rounded-[2.5rem] border border-neutral-border bg-white p-5 md:p-10 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
             <h3 class="text-xs uppercase tracking-[0.3em] text-brand-primary dark:text-brand-light mb-6 font-bold">Orari</h3>
             <ul class="space-y-3 text-sm md:text-base text-neutral-600 dark:text-neutral-300">
               <li class="flex justify-between border-b border-neutral-100 dark:border-neutral-800 pb-2"><span>Lunedì</span> <span class="font-medium">08:30–13, 18–20</span></li>
               <li class="flex justify-between border-b border-neutral-100 dark:border-neutral-800 pb-2"><span>Martedì</span> <span class="font-medium">08:30–13</span></li>
               <li class="flex justify-between border-b border-neutral-100 dark:border-neutral-800 pb-2"><span>Mercoledì</span> <span class="font-medium">08:30–13, 18–20</span></li>
               <li class="flex justify-between border-b border-neutral-100 dark:border-neutral-800 pb-2"><span>Giovedì</span> <span class="font-medium">08:30–12, 14–18</span></li>
               <li class="flex justify-between border-b border-neutral-100 dark:border-neutral-800 pb-2"><span>Venerdì</span> <span class="font-medium">08:30–13</span></li>
               <li class="flex justify-between border-b border-neutral-100 dark:border-neutral-800 pb-2"><span>Sabato</span> <span class="text-neutral-400">Chiuso</span></li>
               <li class="flex justify-between pb-2"><span>Domenica</span> <span class="text-neutral-400">Chiuso</span></li>
             </ul>
          </div>

          <div class="rounded-3xl md:rounded-[2.5rem] bg-gradient-to-br from-brand-primary to-brand-dark p-6 md:p-10 text-white shadow-xl shadow-brand-primary/20 overflow-hidden relative">
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
            <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
            
            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <h3 class="text-lg font-semibold">Presentazione</h3>
              </div>
              
              <p class="text-white/80 leading-relaxed mb-6 text-sm md:text-base">
                Scopri chi sono, il mio metodo di lavoro e come posso aiutarti nella gestione del tuo patrimonio.
              </p>
              
              <a href="/brochure.pdf" download class="group flex items-center gap-3 w-full rounded-2xl bg-white px-5 py-4 text-brand-primary font-bold hover:bg-brand-accent hover:text-white transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                <div class="w-10 h-10 rounded-xl bg-brand-primary/10 group-hover:bg-white/20 flex items-center justify-center transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                  </svg>
                </div>
                <div class="flex-1">
                  <span class="block text-sm">Scarica PDF</span>
                  <span class="block text-xs opacity-70 group-hover:opacity-100">Presentazione Sergio Contegiacomo</span>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7">
          <form class="rounded-3xl md:rounded-[2.5rem] border border-neutral-border bg-white p-5 md:p-10 lg:p-12 shadow-xl shadow-neutral-200/50 dark:border-neutral-800 dark:bg-neutral-900 dark:shadow-none" data-contact-form>
            <h3 class="text-2xl md:text-3xl font-serif text-neutral-900 dark:text-white mb-8 md:mb-10">Invia un messaggio</h3>
            
            <div class="grid gap-5 md:gap-8 grid-cols-1 md:grid-cols-2 mb-5 md:mb-8">
              <div class="space-y-3">
                <label class="text-sm font-bold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider">Nome</label>
                <input
                  type="text"
                  name="nome"
                  required
                  class="w-full rounded-2xl border border-neutral-200 bg-neutral-50 px-5 py-4 text-base focus:border-brand-primary focus:bg-white focus:ring-4 focus:ring-brand-primary/10 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:focus:border-brand-light"
                  placeholder="Il tuo nome"
                />
              </div>
              <div class="space-y-3">
                <label class="text-sm font-bold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider">Cognome</label>
                <input
                  type="text"
                  name="cognome"
                  required
                  class="w-full rounded-2xl border border-neutral-200 bg-neutral-50 px-5 py-4 text-base focus:border-brand-primary focus:bg-white focus:ring-4 focus:ring-brand-primary/10 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:focus:border-brand-light"
                  placeholder="Il tuo cognome"
                />
              </div>
            </div>

            <div class="grid gap-5 md:gap-8 grid-cols-1 md:grid-cols-2 mb-5 md:mb-8">
              <div class="space-y-3">
                <label class="text-sm font-bold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider">Email</label>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full rounded-2xl border border-neutral-200 bg-neutral-50 px-5 py-4 text-base focus:border-brand-primary focus:bg-white focus:ring-4 focus:ring-brand-primary/10 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:focus:border-brand-light"
                  placeholder="nome@esempio.com"
                />
              </div>
              <div class="space-y-3">
                <label class="text-sm font-bold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider">Telefono</label>
                <input
                  type="tel"
                  name="telefono"
                  class="w-full rounded-2xl border border-neutral-200 bg-neutral-50 px-5 py-4 text-base focus:border-brand-primary focus:bg-white focus:ring-4 focus:ring-brand-primary/10 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:focus:border-brand-light"
                  placeholder="+39 ..."
                />
              </div>
            </div>

            <div class="space-y-3 mb-10">
              <label class="text-sm font-bold text-neutral-700 dark:text-neutral-300 uppercase tracking-wider">Messaggio</label>
              <textarea
                name="messaggio"
                rows="5"
                class="w-full rounded-2xl border border-neutral-200 bg-neutral-50 px-5 py-4 text-base focus:border-brand-primary focus:bg-white focus:ring-4 focus:ring-brand-primary/10 transition outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:focus:border-brand-light"
              ></textarea>
            </div>

            <div class="flex items-start gap-3 mb-8">
              <div class="flex items-center h-5">
                <input
                  id="privacy"
                  name="privacy"
                  type="checkbox"
                  required
                  class="h-4 w-4 rounded border-neutral-300 text-brand-primary focus:ring-brand-primary dark:border-neutral-700 dark:bg-neutral-800"
                />
              </div>
              <label for="privacy" class="text-xs text-neutral-500 dark:text-neutral-400">
                Ho letto e accetto l'<a href="/privacy" class="text-brand-primary hover:underline">informativa sulla privacy</a> e acconsento al trattamento dei miei dati personali.
              </label>
            </div>

            <button
              type="submit"
              class="w-full inline-flex items-center justify-center rounded-full bg-brand-primary px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-brand-primary/20 hover:bg-brand-light hover:-translate-y-0.5 transition duration-300"
            >
              Invia messaggio
            </button>
            
            <div class="mt-4 text-center">
              <p class="text-sm font-medium text-green-600 dark:text-green-400 hidden" data-success-message>
                Grazie per il messaggio. Ti risponderò entro 24 ore.
              </p>
              <p class="text-sm font-medium text-red-600 dark:text-red-400 hidden" data-error-message>
                Si è verificato un errore. Riprova più tardi.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const form = document.querySelector('[data-contact-form]');
  const successMsg = document.querySelector('[data-success-message]');
  const errorMsg = document.querySelector('[data-error-message]');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!(form instanceof HTMLFormElement)) return;

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalBtnText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = "Invio in corso...";

    const data = Object.fromEntries(new FormData(form));

    try {
      // Simulazione invio (o endpoint reale se esistente)
      // const res = await fetch('/api/contact', { ... });
      await new Promise(resolve => setTimeout(resolve, 1000)); // Fake delay

      if (successMsg instanceof HTMLElement) successMsg.hidden = false;
      if (errorMsg instanceof HTMLElement) errorMsg.hidden = true;
      form.reset();
    } catch (error) {
      if (errorMsg instanceof HTMLElement) errorMsg.hidden = false;
      if (successMsg instanceof HTMLElement) successMsg.hidden = true;
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalBtnText;
    }
  });
</script>
