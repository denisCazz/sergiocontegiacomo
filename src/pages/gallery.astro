---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { Image } from 'astro:assets';

export const prerender = true;

const imageModules = import.meta.glob('../assets/gallery/*.{jpg,jpeg,png,webp,avif}', { eager: true });
const images = Object.values(imageModules).map((mod: any) => mod.default);
const imagesData = images.map((img: any, i: number) => ({
  src: img.src,
  alt: `Immagine gallery ${i + 1}`,
  width: img.width,
  height: img.height,
}));
---

<BaseLayout
  title="Gallery"
  description="Una selezione di immagini e momenti del mio percorso professionale."
  keywords="gallery Sergio Contegiacomo, foto consulente patrimoniale, eventi finanziari Bra"
  activePath="/gallery"
>
  <section class="py-16 lg:py-24 bg-white dark:bg-neutral-950">
    <div class="mx-auto max-w-6xl px-6">
      <h1 class="sr-only">Gallery fotografica</h1>
      <SectionHeading
        eyebrow="Gallery"
        title="Immagini"
        description="Scorri alcune foto e materiali visivi."
        align="center"
      />

      {images.length === 0 ? (
        <div class="mt-10 rounded-3xl border border-neutral-border bg-neutral-50 p-8 text-center dark:border-neutral-800 dark:bg-neutral-900">
          <p class="text-neutral-muted dark:text-neutral-300">
            Nessuna immagine trovata. Aggiungi i file in
            <span class="font-semibold text-neutral-text dark:text-white"> src/assets/gallery</span>.
          </p>
        </div>
      ) : (
        <div class="mt-10 columns-1 sm:columns-2 lg:columns-3 gap-6">
          {images.map((img, i) => (
            <figure class="group mb-6 break-inside-avoid overflow-hidden rounded-3xl border border-neutral-border bg-white shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
              <button
                type="button"
                class="block w-full text-left"
                data-gallery-item
                data-index={i}
                aria-label={`Apri immagine ${i + 1} in carousel`}
              >
                <Image
                  src={img}
                  alt={`Immagine gallery ${i + 1}`}
                  loading="lazy"
                  class="w-full h-auto transition-transform duration-500 group-hover:scale-[1.03]"
                />
              </button>
            </figure>
          ))}
        </div>
      )}

      <div
        id="gallery-lightbox"
        class="fixed inset-0 z-[80] hidden"
        aria-hidden="true"
        data-images={JSON.stringify(imagesData)}
      >
        <div class="absolute inset-0 bg-neutral-text/70 dark:bg-neutral-950/80 z-0" data-overlay></div>

        <div class="relative z-10 h-full w-full flex items-center justify-center p-4">
          <div
            role="dialog"
            aria-modal="true"
            aria-label="Carousel immagini"
            class="relative w-full max-w-5xl"
            data-dialog
          >
            <div class="overflow-hidden rounded-3xl border border-neutral-border bg-white shadow-2xl dark:border-neutral-800 dark:bg-neutral-900">
              <div class="relative">
                <button
                  type="button"
                  class="absolute top-3 right-3 z-20 inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-primary text-white shadow-lg hover:bg-brand-light transition"
                  aria-label="Chiudi"
                  data-close
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                </button>

                <img
                  data-lightbox-image
                  src=""
                  alt=""
                  class="block w-full h-auto max-h-[80vh] object-contain bg-white dark:bg-neutral-900"
                />

                <button
                  type="button"
                  class="absolute left-3 top-1/2 -translate-y-1/2 inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-neutral-text shadow-md hover:bg-white transition dark:bg-neutral-900/90 dark:text-white"
                  aria-label="Immagine precedente"
                  data-prev
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
                  </svg>
                </button>

                <button
                  type="button"
                  class="absolute right-3 top-1/2 -translate-y-1/2 inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-neutral-text shadow-md hover:bg-white transition dark:bg-neutral-900/90 dark:text-white"
                  aria-label="Immagine successiva"
                  data-next
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const lightbox = document.getElementById('gallery-lightbox');
  const galleryImages = /** @type {{src:string, alt:string, width?:number, height?:number}[]} */ (
    (() => {
      try {
        const raw = lightbox?.getAttribute('data-images') || '[]';
        return JSON.parse(raw);
      } catch {
        return [];
      }
    })()
  );

  const lightboxImg = lightbox?.querySelector('[data-lightbox-image]');
  const dialogEl = lightbox?.querySelector('[data-dialog]');
  const overlay = lightbox?.querySelector('[data-overlay]');
  const btnClose = lightbox?.querySelector('[data-close]');
  const btnPrev = lightbox?.querySelector('[data-prev]');
  const btnNext = lightbox?.querySelector('[data-next]');

  let currentIndex = 0;
  let lastFocused = null;

  const setIndex = (nextIndex) => {
    if (!galleryImages.length || !lightboxImg) return;
    const len = galleryImages.length;
    currentIndex = ((nextIndex % len) + len) % len;
    const item = galleryImages[currentIndex];
    lightboxImg.src = item.src;
    lightboxImg.alt = item.alt;
  };

  const openLightbox = (index) => {
    if (!lightbox) return;
    lastFocused = document.activeElement;
    lightbox.classList.remove('hidden');
    lightbox.setAttribute('aria-hidden', 'false');
    document.documentElement.style.overflow = 'hidden';
    setIndex(index);
    // focus close for accessibility
    btnClose?.focus();
  };

  const closeLightbox = () => {
    if (!lightbox) return;
    lightbox.classList.add('hidden');
    lightbox.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
    if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
  };

  document.querySelectorAll('[data-gallery-item]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = Number(btn.getAttribute('data-index') || '0');
      openLightbox(index);
    });
  });

  btnClose?.addEventListener('click', closeLightbox);
  overlay?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (!dialogEl) return;
    const target = e.target;
    if (!(target instanceof Node)) return;
    // Chiudi solo se il click è fuori dal box del carousel
    if (!dialogEl.contains(target)) closeLightbox();
  });
  btnPrev?.addEventListener('click', () => setIndex(currentIndex - 1));
  btnNext?.addEventListener('click', () => setIndex(currentIndex + 1));

  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') {
      e.preventDefault();
      closeLightbox();
      return;
    }
    if (e.key === 'ArrowLeft') {
      e.preventDefault();
      setIndex(currentIndex - 1);
      return;
    }
    if (e.key === 'ArrowRight') {
      e.preventDefault();
      setIndex(currentIndex + 1);
      return;
    }
  });
</script>
