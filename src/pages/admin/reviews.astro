---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Gestione Recensioni">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Recensioni</h1>
  </div>

  <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
    <ul id="reviewsList" class="divide-y divide-gray-200 dark:divide-gray-700">
      <li class="p-4 text-center text-gray-500 dark:text-gray-400">Caricamento...</li>
    </ul>
  </div>

  <script>
    import { getAllComments, deleteComment } from '../../lib/cms';
    import dayjs from 'dayjs';

    const list = document.getElementById('reviewsList');

    const renderReviews = async () => {
      if (!list) return;
      list.innerHTML = '<li class="p-4 text-center text-gray-500 dark:text-gray-400">Caricamento...</li>';

      const comments = await getAllComments();

      if (!comments || comments.length === 0) {
        list.innerHTML = '<li class="p-4 text-center text-gray-500">Nessuna recensione trovata.</li>';
        return;
      }

      list.innerHTML = comments.map(comment => `
        <li>
          <div class="px-4 py-4 sm:px-6 hover:bg-gray-50 dark:hover:bg-gray-700 transition duration-150 ease-in-out">
            <div class="flex items-center justify-between mb-2">
              <div class="text-sm font-medium text-brand-primary truncate">
                ${comment.user_name} <span class="text-gray-500 dark:text-gray-400 text-xs">su ${comment.article_slug}</span>
              </div>
              <div class="ml-2 flex-shrink-0 flex">
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                  ${comment.rating} ★
                </span>
              </div>
            </div>
            <div class="mt-2 sm:flex sm:justify-between">
              <div class="sm:flex">
                <p class="flex items-center text-sm text-gray-500 dark:text-gray-300">
                  ${comment.content}
                </p>
              </div>
              <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                <p>
                  ${dayjs(comment.created_at).format('DD/MM/YYYY HH:mm')}
                </p>
                <button 
                  data-id="${comment.id}"
                  class="delete-btn ml-4 text-red-600 hover:text-red-900 font-medium"
                >
                  Elimina
                </button>
              </div>
            </div>
          </div>
        </li>
      `).join('');

      // Add event listeners for delete buttons
      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          if (!confirm('Sei sicuro di voler eliminare questa recensione?')) return;
          
          const id = parseInt((e.target as HTMLElement).dataset.id || '0');
          if (id) {
            const success = await deleteComment(id);
            if (success) {
              renderReviews(); // Reload list
            } else {
              alert('Errore durante l\'eliminazione');
            }
          }
        });
      });
    };

    renderReviews();
  </script>
</AdminLayout>
