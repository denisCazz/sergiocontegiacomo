---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <!-- Header con saluto dinamico -->
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white" id="greeting">Benvenuto!</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">
          <span id="currentDate"></span> • Gestisci i contenuti del tuo sito
        </p>
      </div>
      <div class="mt-4 sm:mt-0">
        <a href="/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Vedi sito
        </a>
      </div>
    </div>
  </div>

  <!-- Statistiche con azioni rapide integrate -->
  <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
    <div class="group relative rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 p-4 text-white shadow-md transition hover:shadow-lg">
      <a href="/admin/articles" class="block">
        <p class="text-[11px] font-medium text-blue-100 uppercase tracking-wide">Articoli</p>
        <p class="text-2xl font-bold mt-1" id="stat-articles">-</p>
      </a>
      <a href="/admin/articles/new" class="absolute top-3 right-3 flex h-7 w-7 items-center justify-center rounded-lg bg-white/20 text-white hover:bg-white/40 transition" title="Nuovo Articolo">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
      </a>
    </div>
    <div class="group relative rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 p-4 text-white shadow-md transition hover:shadow-lg">
      <a href="/admin/audio" class="block">
        <p class="text-[11px] font-medium text-purple-100 uppercase tracking-wide">Audio</p>
        <p class="text-2xl font-bold mt-1" id="stat-audio">-</p>
      </a>
      <a href="/admin/audio/new" class="absolute top-3 right-3 flex h-7 w-7 items-center justify-center rounded-lg bg-white/20 text-white hover:bg-white/40 transition" title="Nuova AudioPillola">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
      </a>
    </div>
    <div class="group relative rounded-xl bg-gradient-to-br from-brand-accent to-brand-accent/80 p-4 text-white shadow-md transition hover:shadow-lg">
      <a href="/admin/podcast" class="block">
        <p class="text-[11px] font-medium text-white/90 uppercase tracking-wide">Podcast</p>
        <p class="text-2xl font-bold mt-1" id="stat-podcasts">-</p>
      </a>
      <a href="/admin/podcast/new" class="absolute top-3 right-3 flex h-7 w-7 items-center justify-center rounded-lg bg-white/20 text-white hover:bg-white/40 transition" title="Nuovo Podcast">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
      </a>
    </div>
    <div class="group relative rounded-xl bg-gradient-to-br from-amber-500 to-orange-500 p-4 text-white shadow-md transition hover:shadow-lg">
      <a href="/admin/events" class="block">
        <p class="text-[11px] font-medium text-amber-100 uppercase tracking-wide">Eventi</p>
        <p class="text-2xl font-bold mt-1" id="stat-events">-</p>
      </a>
      <a href="/admin/events/new" class="absolute top-3 right-3 flex h-7 w-7 items-center justify-center rounded-lg bg-white/20 text-white hover:bg-white/40 transition" title="Nuovo Evento">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
      </a>
    </div>
    <div class="group relative rounded-xl bg-gradient-to-br from-rose-500 to-pink-500 p-4 text-white shadow-md transition hover:shadow-lg">
      <a href="/admin/press" class="block">
        <p class="text-[11px] font-medium text-rose-100 uppercase tracking-wide">Stampa</p>
        <p class="text-2xl font-bold mt-1" id="stat-press">-</p>
      </a>
      <a href="/admin/press/new" class="absolute top-3 right-3 flex h-7 w-7 items-center justify-center rounded-lg bg-white/20 text-white hover:bg-white/40 transition" title="Nuova Rassegna">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
      </a>
    </div>
    <div class="group relative rounded-xl bg-gradient-to-br from-yellow-500 to-yellow-600 p-4 text-white shadow-md transition hover:shadow-lg">
      <a href="/admin/testimonials" class="block">
        <p class="text-[11px] font-medium text-yellow-100 uppercase tracking-wide">Recensioni</p>
        <p class="text-2xl font-bold mt-1" id="stat-testimonials">-</p>
      </a>
      <a href="/admin/testimonials/new" class="absolute top-3 right-3 flex h-7 w-7 items-center justify-center rounded-lg bg-white/20 text-white hover:bg-white/40 transition" title="Nuova Recensione">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
      </a>
    </div>
  </div>

  <!-- Attività recenti -->
  <div>
    <h2 class="mb-3 text-base font-semibold text-gray-900 dark:text-white">Ultimi Contenuti Aggiunti</h2>
    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
      <ul id="recentActivity" class="divide-y divide-gray-200 dark:divide-gray-700">
        <li class="p-4 text-center text-gray-500 dark:text-gray-400">
          <div class="flex items-center justify-center gap-2">
            <svg class="h-5 w-5 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Caricamento...
          </div>
        </li>
      </ul>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase';
    import dayjs from 'dayjs';
    import 'dayjs/locale/it';
    dayjs.locale('it');

    // Saluto dinamico in base all'ora
    const hour = new Date().getHours();
    let greeting = 'Buongiorno';
    if (hour >= 13 && hour < 18) greeting = 'Buon pomeriggio';
    else if (hour >= 18) greeting = 'Buonasera';
    
    const greetingEl = document.getElementById('greeting');
    if (greetingEl) greetingEl.textContent = `${greeting}! 👋`;

    // Data corrente
    const dateEl = document.getElementById('currentDate');
    if (dateEl) dateEl.textContent = dayjs().format('dddd D MMMM YYYY');

    const loadStats = async () => {
      const [articles, audio, events, press, podcasts, testimonials] = await Promise.all([
        supabase.from('articles').select('id', { count: 'exact', head: true }),
        supabase.from('audio_pillole').select('id', { count: 'exact', head: true }),
        supabase.from('events').select('id', { count: 'exact', head: true }),
        supabase.from('press').select('id', { count: 'exact', head: true }),
        supabase.from('podcasts').select('id', { count: 'exact', head: true }),
        supabase.from('testimonials').select('id', { count: 'exact', head: true }),
      ]);

      document.getElementById('stat-articles')!.textContent = String(articles.count || 0);
      document.getElementById('stat-audio')!.textContent = String(audio.count || 0);
      document.getElementById('stat-podcasts')!.textContent = String(podcasts.count || 0);
      document.getElementById('stat-events')!.textContent = String(events.count || 0);
      document.getElementById('stat-press')!.textContent = String(press.count || 0);
      document.getElementById('stat-testimonials')!.textContent = String(testimonials.count || 0);
    };

    // Carica attività recenti
    const loadRecentActivity = async () => {
      const [articles, audio, events, press, podcasts] = await Promise.all([
        supabase.from('articles').select('id, title, created_at').order('created_at', { ascending: false }).limit(3),
        supabase.from('audio_pillole').select('id, title, created_at').order('created_at', { ascending: false }).limit(3),
        supabase.from('events').select('id, title, created_at').order('created_at', { ascending: false }).limit(3),
        supabase.from('press').select('id, title, created_at').order('created_at', { ascending: false }).limit(3),
        supabase.from('podcasts').select('id, title, created_at').order('created_at', { ascending: false }).limit(3),
      ]);

      type ActivityItem = { id: string; title: string; created_at: string; type: string; color: string; link: string };
      const allItems: ActivityItem[] = [
        ...(articles.data || []).map((a: any) => ({ ...a, type: 'Articolo', color: 'blue', link: `/admin/articles/edit?id=${a.id}` })),
        ...(audio.data || []).map((a: any) => ({ ...a, type: 'Audio', color: 'purple', link: `/admin/audio/edit?id=${a.id}` })),
        ...(events.data || []).map((e: any) => ({ ...e, type: 'Evento', color: 'amber', link: `/admin/events` })),
        ...(press.data || []).map((p: any) => ({ ...p, type: 'Stampa', color: 'rose', link: `/admin/press/edit?id=${p.id}` })),
        ...(podcasts.data || []).map((p: any) => ({ ...p, type: 'Podcast', color: 'teal', link: `/admin/podcast/edit?id=${p.id}` })),
      ];

      allItems.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
      const recent = allItems.slice(0, 8);

      const list = document.getElementById('recentActivity');
      if (!list) return;

      if (recent.length === 0) {
        list.innerHTML = '<li class="p-4 text-center text-gray-500 dark:text-gray-400">Nessuna attivita\' recente</li>';
        return;
      }

      const badgeColors: Record<string, string> = {
        blue: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
        purple: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400',
        amber: 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400',
        rose: 'bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400',
        teal: 'bg-teal-100 text-teal-700 dark:bg-teal-900/30 dark:text-teal-400',
      };

      list.innerHTML = recent.map(item => `
        <li>
          <a href="${item.link}" class="flex items-center gap-4 px-4 py-3 transition hover:bg-gray-50 dark:hover:bg-gray-700/50">
            <span class="inline-flex items-center rounded-md px-2 py-1 text-[11px] font-bold uppercase tracking-wider ${badgeColors[item.color] || badgeColors.blue}">${item.type}</span>
            <div class="flex-1 min-w-0">
              <p class="truncate text-sm font-medium text-gray-900 dark:text-white">${item.title}</p>
            </div>
            <span class="flex-shrink-0 text-xs text-gray-400 dark:text-gray-500">${dayjs(item.created_at).format('D MMM YYYY')}</span>
            <svg class="h-4 w-4 flex-shrink-0 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </li>
      `).join('');
    };

    loadStats();
    loadRecentActivity();
  </script>
</AdminLayout>
