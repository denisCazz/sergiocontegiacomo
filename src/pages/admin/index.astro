---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Benvenuto, Admin</h1>
    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Ecco una panoramica delle attività del sito.</p>
  </div>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <!-- Articles Card -->
    <div class="relative overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-md dark:bg-gray-800 dark:ring-gray-700">
      <dt>
        <div class="absolute rounded-md bg-brand-primary/10 p-3">
          <svg class="h-6 w-6 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <p class="ml-16 truncate text-sm font-medium text-gray-500 dark:text-gray-400">Blog</p>
      </dt>
      <dd class="ml-16 flex items-baseline pb-1 sm:pb-2">
        <p class="text-2xl font-semibold text-gray-900 dark:text-white">Articoli</p>
      </dd>
      <div class="mt-4 border-t border-gray-100 pt-4 dark:border-gray-700">
        <div class="flex items-center justify-between text-sm">
          <a href="/admin/articles" class="font-medium text-brand-primary hover:text-brand-dark">Gestisci</a>
          <a href="/admin/articles/new" class="font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">+ Nuovo</a>
        </div>
      </div>
    </div>

    <!-- AudioPillole Card -->
    <div class="relative overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-md dark:bg-gray-800 dark:ring-gray-700">
      <dt>
        <div class="absolute rounded-md bg-purple-100 p-3 dark:bg-purple-900/30">
          <svg class="h-6 w-6 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
          </svg>
        </div>
        <p class="ml-16 truncate text-sm font-medium text-gray-500 dark:text-gray-400">Media</p>
      </dt>
      <dd class="ml-16 flex items-baseline pb-1 sm:pb-2">
        <p class="text-2xl font-semibold text-gray-900 dark:text-white">AudioPillole</p>
      </dd>
      <div class="mt-4 border-t border-gray-100 pt-4 dark:border-gray-700">
        <div class="flex items-center justify-between text-sm">
          <a href="/admin/audio" class="font-medium text-brand-primary hover:text-brand-dark">Gestisci</a>
          <a href="/admin/audio/new" class="font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">+ Nuovo</a>
        </div>
      </div>
    </div>

    <!-- Press Card -->
    <div class="relative overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-md dark:bg-gray-800 dark:ring-gray-700">
      <dt>
        <div class="absolute rounded-md bg-red-100 p-3 dark:bg-red-900/30">
          <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        <p class="ml-16 truncate text-sm font-medium text-gray-500 dark:text-gray-400">Stampa</p>
      </dt>
      <dd class="ml-16 flex items-baseline pb-1 sm:pb-2">
        <p class="text-2xl font-semibold text-gray-900 dark:text-white">Rassegna Stampa</p>
      </dd>
      <div class="mt-4 border-t border-gray-100 pt-4 dark:border-gray-700">
        <div class="flex items-center justify-between text-sm">
          <a href="/admin/press" class="font-medium text-brand-primary hover:text-brand-dark">Gestisci</a>
          <a href="/admin/press/new" class="font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">+ Nuovo</a>
        </div>
      </div>
    </div>

    <!-- Events Card -->
    <div class="relative overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-md dark:bg-gray-800 dark:ring-gray-700">
      <dt>
        <div class="absolute rounded-md bg-brand-accent/10 p-3">
          <svg class="h-6 w-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <p class="ml-16 truncate text-sm font-medium text-gray-500 dark:text-gray-400">Eventi</p>
      </dt>
      <dd class="ml-16 flex items-baseline pb-1 sm:pb-2">
        <p class="text-2xl font-semibold text-gray-900 dark:text-white">Calendario</p>
      </dd>
      <div class="mt-4 border-t border-gray-100 pt-4 dark:border-gray-700">
        <div class="flex items-center justify-between text-sm">
          <a href="/admin/events" class="font-medium text-brand-primary hover:text-brand-dark">Gestisci</a>
          <a href="/admin/events/new" class="font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">+ Nuovo</a>
        </div>
      </div>
    </div>

    <!-- Reviews Card -->
    <div class="relative overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-md dark:bg-gray-800 dark:ring-gray-700">
      <dt>
        <div class="absolute rounded-md bg-yellow-100 p-3">
          <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
        </div>
        <p class="ml-16 truncate text-sm font-medium text-gray-500 dark:text-gray-400">Community</p>
      </dt>
      <dd class="ml-16 flex items-baseline pb-1 sm:pb-2">
        <p class="text-2xl font-semibold text-gray-900 dark:text-white">Recensioni</p>
      </dd>
      <div class="mt-4 border-t border-gray-100 pt-4 dark:border-gray-700">
        <div class="flex items-center justify-between text-sm">
          <a href="/admin/reviews" class="font-medium text-brand-primary hover:text-brand-dark">Visualizza tutte</a>
        </div>
      </div>
    </div>

    <!-- Users Card -->
    <div class="relative overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-md dark:bg-gray-800 dark:ring-gray-700">
      <dt>
        <div class="absolute rounded-md bg-green-100 p-3 dark:bg-green-900/30">
          <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </div>
        <p class="ml-16 truncate text-sm font-medium text-gray-500 dark:text-gray-400">Sistema</p>
      </dt>
      <dd class="ml-16 flex items-baseline pb-1 sm:pb-2">
        <p class="text-2xl font-semibold text-gray-900 dark:text-white">Utenti</p>
      </dd>
      <div class="mt-4 border-t border-gray-100 pt-4 dark:border-gray-700">
        <div class="flex items-center justify-between text-sm">
          <a href="/admin/users" class="font-medium text-brand-primary hover:text-brand-dark">Gestisci</a>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
