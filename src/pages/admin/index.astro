---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Gestione eventi e blog">
  <div class="mb-6 flex justify-end">
    <a href="/" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-brand-primary bg-brand-primary/10 hover:bg-brand-primary/20 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Torna al sito
    </a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Articles Card -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-brand-primary/10 rounded-md p-3">
            <svg class="h-6 w-6 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate dark:text-gray-400">Gestione Blog</dt>
              <dd>
                <div class="text-lg font-medium text-gray-900 dark:text-white">Articoli</div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 dark:bg-gray-700 px-5 py-3">
        <div class="text-sm">
          <a href="/admin/articles" class="font-medium text-brand-primary hover:text-brand-dark">Vedi tutti gli articoli</a>
          <span class="mx-2 text-gray-300">|</span>
          <a href="/admin/articles/new" class="font-medium text-brand-primary hover:text-brand-dark">Crea nuovo</a>
        </div>
      </div>
    </div>

    <!-- Events Card -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-brand-accent/10 rounded-md p-3">
            <svg class="h-6 w-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate dark:text-gray-400">Gestione Eventi</dt>
              <dd>
                <div class="text-lg font-medium text-gray-900 dark:text-white">Eventi</div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 dark:bg-gray-700 px-5 py-3">
        <div class="text-sm">
          <a href="/admin/events" class="font-medium text-brand-primary hover:text-brand-dark">Vedi tutti gli eventi</a>
          <span class="mx-2 text-gray-300">|</span>
          <a href="/admin/events/new" class="font-medium text-brand-primary hover:text-brand-dark">Crea nuovo</a>
        </div>
      </div>
    </div>

    <!-- Reviews Card -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-yellow-100 rounded-md p-3">
            <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 truncate dark:text-gray-400">Gestione Recensioni</dt>
              <dd>
                <div class="text-lg font-medium text-gray-900 dark:text-white">Recensioni</div>
              </dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 dark:bg-gray-700 px-5 py-3">
        <div class="text-sm">
          <a href="/admin/reviews" class="font-medium text-brand-primary hover:text-brand-dark">Gestisci recensioni</a>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
