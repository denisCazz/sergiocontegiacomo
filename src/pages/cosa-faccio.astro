---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';

const pillars = [
  {
    title: "Analisi e Diagnosi",
    description:
      "Costruzione conto economico e stato patrimoniale più definizione obiettivi con scala di priorità.",
    items: ["Analisi risorse patrimoniali e reddituali", "Analisi rischi intangibili (tutele personali e famigliari in essere)", "Creazione obiettivi nel tempo"],
  },
  {
    title: "Presentazione strategia operativa",
    description:
      "Prima ti tutelo, poi investiamo.",
    items: ["Rimozione dei 'non si sa mai'", "Efficientamento del tuo portafoglio di investimenti sulla base della tua propoensione/tolleranza al rischio", "Generare valore dalla tua fiscalita'"],
  },
  {
    title: "Coaching e Monitoraggio",
    description:
      "Sessioni periodiche di coaching per mantenere focus e lucidita' e schivare le trappole mentali.",
    items: ["Vicinanza, disponibilità e reperibilità", "Assistenza periodica", "Variazione strategia al cambiare della tua situazione soggetttiva ed oggettiva"],
  },
];

const workflow = [
  {
    title: "Assessment iniziale",
    description:
      "Incontri di ascolto, raccolta documentale e costruzione del tuo stato patrimoniale completo.",
  },
  {
    title: "Visione condivisa",
    description: "Definizione congiunta di obiettivi, timeline e indicatori di successo. Consegna del piano strategico.",
  },
  {
    title: "Implementazione guidata",
    description: "Teamworking con altri professionisti per attuare le soluzioni definite.",
  },
  {
    title: "Coaching continuo",
    description: "Sessioni periodiche e regolari per rivedere risultati, adeguare strategie e gestire i momenti critici.",
  },
];
---

<BaseLayout 
  title="Cosa Faccio" 
  description="Scopri i servizi di Sergio Contegiacomo: consulenza patrimoniale, coaching finanziario, analisi e diagnosi, strategia e governance del patrimonio."
  keywords="servizi consulenza patrimoniale, coaching finanziario, wealth management, pianificazione patrimoniale, governance familiare"
  activePath="/cosa-faccio"
>
  <section class="relative py-24 lg:py-32 bg-neutral-base dark:bg-neutral-950 overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-full pointer-events-none">
      <div class="absolute top-20 right-0 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6 space-y-24 relative z-10">
      <div class="max-w-4xl mx-auto text-center space-y-8">
        <div class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary shadow-sm dark:bg-neutral-900 dark:text-brand-light border border-neutral-100 dark:border-neutral-800">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
          Servizi
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif font-medium text-neutral-text dark:text-white leading-[1.1] tracking-tight">
          Consulenza Patrimoniale Olistica<br class="hidden md:block" />
        </h1>
        <p class="text-xl md:text-2xl text-neutral-muted leading-relaxed dark:text-neutral-300 max-w-2xl mx-auto font-light">
          Costruiamo insieme il benessere della tua famiglia in un mondo in cui tutto cambia velocemente.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {pillars.map((pillar) => (
          <ServiceCard {...pillar} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-white dark:bg-neutral-950">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid lg:grid-cols-2 gap-20 lg:gap-32 items-start">
        <div class="lg:sticky lg:top-32 space-y-10">
          <SectionHeading
            eyebrow="PROCESSO"
            title="Un percorso a tappe per farti prendere decisioni lucide, efficaci ed efficienti."
            description="Ti ascolto, ti faccio domande per conoscere te e la tua famiglia per aiutarti a raggiungere i tuoi obiettivi e i tuoi sogni."
          />
          <div class="p-10 bg-neutral-50 rounded-[2.5rem] border border-neutral-100 dark:bg-neutral-900 dark:border-neutral-800">
            <p class="font-serif italic text-2xl text-brand-primary dark:text-brand-light mb-6 leading-relaxed">
              "Il metodo è la bussola che ci permette di navigare l'incertezza senza perdere la rotta."
            </p>
            <div class="flex items-center gap-4">
              <div class="h-10 w-10 rounded-full bg-brand-primary/10 flex items-center justify-center text-brand-primary font-bold text-sm">SC</div>
              <p class="text-sm font-bold uppercase tracking-wider text-neutral-900 dark:text-white">Sergio Contegiacomo</p>
            </div>
          </div>
        </div>

        <div class="space-y-12 relative py-4">
          <div class="absolute left-8 top-8 bottom-8 w-px bg-neutral-200 dark:bg-neutral-800 hidden md:block"></div>
          
          {workflow.map((step, index) => (
            <div class="relative pl-0 md:pl-28 group">
              <div class="hidden md:flex absolute left-0 top-0 h-16 w-16 items-center justify-center rounded-full border-4 border-white bg-neutral-100 text-xl font-bold text-brand-primary shadow-sm group-hover:bg-brand-primary group-hover:text-white transition duration-300 dark:border-neutral-950 dark:bg-neutral-900 dark:text-brand-light z-10">
                {index + 1}
              </div>
              
              <div class="rounded-3xl border border-neutral-border bg-white p-8 shadow-sm transition duration-300 hover:shadow-card hover:-translate-y-1 dark:border-neutral-800 dark:bg-neutral-900">
                <div class="md:hidden mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-primary/10 text-brand-primary font-bold text-sm">
                  {index + 1}
                </div>
                <h3 class="text-xl font-semibold text-neutral-text dark:text-white mb-3">{step.title}</h3>
                <p class="text-neutral-muted leading-relaxed dark:text-neutral-300">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Vuoi migliorare la gestione dei tuoi investimenti e del tuo portafoglio?"
    description="Sono disponibile a mettere al tuo servizio le mie competenze e la mia esperienza di oltre 35 anni nel settore finanziario."
    primaryCta={{ label: 'Prenota una call introduttiva', href: '/contatti' }}
    secondaryCta={{ label: 'Richiedi case study', href: '/contatti?type=case-study' }}
  />
</BaseLayout>
