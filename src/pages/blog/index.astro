---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getArticles, getAllArticleStats, type Article, type ArticleStats } from '../../lib/cms';

const page = Number(Astro.url.searchParams.get('page') ?? '1');
const activeTag = Astro.url.searchParams.get('tag') ?? undefined;
const searchQuery = Astro.url.searchParams.get('q') ?? undefined;

const { data: articleEntries, meta } = await getArticles({
  pagination: { page, pageSize: 12 },
  filters: activeTag ? { tags: { $containsi: activeTag } } : undefined,
});

let articles = (articleEntries ?? []).map((entry) => entry.attributes as Article);

// Filter by search query
if (searchQuery) {
  const query = searchQuery.toLowerCase();
  articles = articles.filter((article) =>
    article.title.toLowerCase().includes(query) ||
    article.excerpt?.toLowerCase().includes(query) ||
    article.content?.toLowerCase().includes(query)
  );
}

// Load article stats (ratings and comment counts)
const allStats = await getAllArticleStats();
const statsMap = new Map<string, ArticleStats>();
allStats.forEach((stat) => {
  statsMap.set(stat.article_slug, stat);
});

// Get all tags from all articles
const allEntries = await getArticles();
const tagSet = new Set<string>();
(allEntries.data ?? []).forEach((entry) => {
  (entry.attributes as Article).tags?.forEach((tag) => tagSet.add(tag));
});
const tags = Array.from(tagSet).sort();

const pagination = meta?.pagination ?? { page: 1, pageCount: 1 };
---

<BaseLayout 
  title="Blog" 
  description="Blog di Sergio Contegiacomo: articoli su gestione patrimoniale, finanza comportamentale, wealth management e strategie di investimento."
  keywords="blog finanza personale, articoli wealth management, consigli investimento, finanza comportamentale, educazione finanziaria"
  activePath="/blog"
>
  <section class="relative py-16 lg:py-24 bg-neutral-base dark:bg-neutral-950 overflow-hidden min-h-screen">
    <div class="absolute top-0 right-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-brand-accent/5 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6 relative z-10">
      <!-- Header compatto -->
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-10">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary shadow-sm dark:bg-neutral-900 dark:text-brand-light border border-neutral-100 dark:border-neutral-800 mb-4">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
            Blog
          </div>
          <h1 class="text-3xl md:text-4xl font-serif font-medium text-neutral-text dark:text-white">
            Pensieri e strumenti per la <span class="text-brand-primary italic">gestione del patrimonio</span>
          </h1>
        </div>
        
        <!-- Link rapidi -->
        <div class="flex flex-wrap gap-3">
          <a href="/blog/audiopillole" class="group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-brand-primary to-brand-primary/80 px-4 py-2.5 text-sm font-medium text-white shadow-lg shadow-brand-primary/20 hover:shadow-brand-primary/40 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
            AudioPillole
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href="/blog/rassegna-stampa" class="group inline-flex items-center gap-2 rounded-full border-2 border-brand-primary/20 bg-white px-4 py-2.5 text-sm font-medium text-brand-primary hover:bg-brand-primary hover:text-white transition-all dark:bg-neutral-900 dark:border-brand-primary/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            Rassegna Stampa
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Barra filtri e ricerca -->
      <div class="bg-white dark:bg-neutral-900 rounded-2xl border border-neutral-200 dark:border-neutral-800 p-4 mb-8 shadow-sm">
        <div class="flex flex-col lg:flex-row gap-4">
          <!-- Ricerca -->
          <div class="flex-1">
            <form method="get" class="relative">
              <input 
                type="text" 
                name="q" 
                value={searchQuery ?? ''}
                placeholder="Cerca per titolo o contenuto..." 
                class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 pl-11 text-sm focus:border-brand-primary focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-primary/20 dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:placeholder-neutral-400"
              />
              <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              {activeTag && <input type="hidden" name="tag" value={activeTag} />}
              <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 rounded-lg bg-brand-primary px-3 py-1.5 text-xs font-medium text-white hover:bg-brand-primary/90 transition">
                Cerca
              </button>
            </form>
          </div>
          
          <!-- Filtri -->
          <div class="flex flex-wrap items-center gap-3">
            <!-- Dropdown Tag -->
            <div class="relative">
              <select 
                id="tag-select" 
                class="appearance-none rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 pr-10 text-sm focus:border-brand-primary focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white cursor-pointer min-w-[140px]"
              >
                <option value="">Tutti i tag</option>
                {tags.map((tag) => (
                  <option value={tag} selected={activeTag === tag}>{tag}</option>
                ))}
              </select>
              <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
            
            <!-- Ordinamento -->
            <div class="relative">
              <select 
                id="sort-select" 
                class="appearance-none rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 pr-10 text-sm focus:border-brand-primary focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white cursor-pointer min-w-[140px]"
              >
                <option value="recent">Più recenti</option>
                <option value="oldest">Meno recenti</option>
                <option value="rated">Più votati</option>
                <option value="az">A-Z</option>
              </select>
              <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
            
            <!-- Reset filtri -->
            {(activeTag || searchQuery) && (
              <a 
                href="/blog" 
                class="inline-flex items-center gap-1.5 rounded-xl border border-red-200 bg-red-50 px-3 py-2.5 text-sm font-medium text-red-600 hover:bg-red-100 transition dark:border-red-800 dark:bg-red-900/20 dark:text-red-400"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Reset
              </a>
            )}
          </div>
        </div>
        
        <!-- Tag attivi / risultati -->
        <div class="flex flex-wrap items-center gap-2 mt-4 pt-4 border-t border-neutral-100 dark:border-neutral-800">
          <span class="text-sm text-neutral-500 dark:text-neutral-400">
            {articles.length} {articles.length === 1 ? 'articolo' : 'articoli'}
            {activeTag && <span> in <span class="font-medium text-brand-primary">{activeTag}</span></span>}
            {searchQuery && <span> per "<span class="font-medium text-brand-primary">{searchQuery}</span>"</span>}
          </span>
          
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 ml-auto">
              {tags.slice(0, 5).map((tag) => (
                <a 
                  href={activeTag === tag ? '/blog' : `/blog?tag=${encodeURIComponent(tag)}`}
                  class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium transition ${
                    activeTag === tag 
                      ? 'bg-brand-primary text-white' 
                      : 'bg-neutral-100 text-neutral-600 hover:bg-brand-primary/10 hover:text-brand-primary dark:bg-neutral-800 dark:text-neutral-300'
                  }`}
                >
                  {tag}
                </a>
              ))}
              {tags.length > 5 && (
                <span class="text-xs text-neutral-400">+{tags.length - 5} altri</span>
              )}
            </div>
          )}
        </div>
      </div>

      <!-- Griglia articoli -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" id="articles-grid">
        {articles.length > 0 ? (
          articles.map((article) => {
            const stats = statsMap.get(article.slug);
            return (
              <div 
                data-slug={article.slug} 
                data-date={article.publishedAt} 
                data-rating={stats?.average_rating ?? 0}
                data-title={article.title}
                class="article-item"
              >
                <BlogCard article={article} rating={stats?.average_rating} commentCount={stats?.comment_count} />
              </div>
            );
          })
        ) : (
          <div class="col-span-full py-20 text-center">
            <div class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-neutral-100 text-neutral-400 mb-6 dark:bg-neutral-800">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <p class="text-xl font-medium text-neutral-900 dark:text-white mb-2">Nessun articolo trovato</p>
            <p class="text-neutral-500 dark:text-neutral-400 max-w-md mx-auto mb-6">
              Non ci sono articoli che corrispondono ai criteri di ricerca.
            </p>
            <a href="/blog" class="inline-flex items-center gap-2 rounded-full bg-brand-primary px-6 py-3 text-sm font-medium text-white hover:bg-brand-primary/90 transition">
              Vedi tutti gli articoli
            </a>
          </div>
        )}
      </div>
      
      <!-- Paginazione -->
      {articles.length > 0 && (
        <div class="mt-12">
          <Pagination
            page={pagination.page ?? 1}
            pageCount={pagination.pageCount ?? 1}
            basePath="/blog"
            query={{ tag: activeTag, q: searchQuery }}
          />
        </div>
      )}
      
      <!-- Sezione altri contenuti -->
      <div class="mt-16 pt-16 border-t border-neutral-200 dark:border-neutral-800">
        <h2 class="text-2xl font-serif font-medium text-neutral-text dark:text-white mb-8 text-center">
          Esplora altri contenuti
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- AudioPillole card -->
          <a href="/blog/audiopillole" class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-primary to-brand-primary/80 p-8 text-white shadow-xl shadow-brand-primary/20 hover:shadow-brand-primary/40 transition-all hover:-translate-y-1">
            <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative z-10">
              <div class="w-14 h-14 rounded-2xl bg-white/20 backdrop-blur-sm flex items-center justify-center mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                </svg>
              </div>
              <h3 class="text-2xl font-semibold mb-3">AudioPillole</h3>
              <p class="text-white/80 mb-6 leading-relaxed">Brevi contenuti audio per approfondire temi di finanza personale, investimenti e gestione patrimoniale. Ascolta ovunque tu sia.</p>
              <span class="inline-flex items-center gap-2 font-medium">
                Ascolta ora
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
          
          <!-- Rassegna Stampa card -->
          <a href="/blog/rassegna-stampa" class="group relative overflow-hidden rounded-3xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 p-8 shadow-sm hover:shadow-xl transition-all hover:-translate-y-1">
            <div class="absolute top-0 right-0 w-32 h-32 bg-brand-primary/5 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative z-10">
              <div class="w-14 h-14 rounded-2xl bg-brand-primary/10 flex items-center justify-center mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
              </div>
              <h3 class="text-2xl font-semibold text-neutral-text dark:text-white mb-3">Rassegna Stampa</h3>
              <p class="text-neutral-muted dark:text-neutral-300 mb-6 leading-relaxed">Articoli, interviste e pubblicazioni su testate giornalistiche nazionali e locali. Scopri cosa dicono di noi.</p>
              <span class="inline-flex items-center gap-2 font-medium text-brand-primary">
                Sfoglia la rassegna
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Tag select
  const tagSelect = document.getElementById('tag-select') as HTMLSelectElement | null;
  if (tagSelect) {
    tagSelect.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      const url = new URL(window.location.href);
      if (target.value) {
        url.searchParams.set('tag', target.value);
      } else {
        url.searchParams.delete('tag');
      }
      url.searchParams.delete('page');
      window.location.href = url.toString();
    });
  }

  // Sort select
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
  const grid = document.getElementById('articles-grid');
  const items = Array.from(document.querySelectorAll('.article-item'));

  function sortArticles(criteria: string) {
    if (!grid || items.length === 0) return;

    items.sort((a, b) => {
      switch (criteria) {
        case 'rated':
          const ratingA = parseFloat(a.getAttribute('data-rating') || '0');
          const ratingB = parseFloat(b.getAttribute('data-rating') || '0');
          return ratingB - ratingA;
        case 'oldest':
          const dateOldA = a.getAttribute('data-date') || '';
          const dateOldB = b.getAttribute('data-date') || '';
          return new Date(dateOldA).getTime() - new Date(dateOldB).getTime();
        case 'az':
          const titleA = a.getAttribute('data-title') || '';
          const titleB = b.getAttribute('data-title') || '';
          return titleA.localeCompare(titleB, 'it');
        default: // recent
          const dateNewA = a.getAttribute('data-date') || '';
          const dateNewB = b.getAttribute('data-date') || '';
          return new Date(dateNewB).getTime() - new Date(dateNewA).getTime();
      }
    });

    items.forEach(item => grid.appendChild(item));
  }

  if (sortSelect) {
    sortSelect.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      sortArticles(target.value);
    });
  }
</script>
