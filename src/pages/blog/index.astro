---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import BlogCard from '../../components/BlogCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import Pagination from '../../components/Pagination.astro';
import { getArticles, type Article } from '../../lib/cms';

const page = Number(Astro.url.searchParams.get('page') ?? '1');
const activeTag = Astro.url.searchParams.get('tag') ?? undefined;

const { data: articleEntries, meta } = await getArticles({
  pagination: { page, pageSize: 9 },
  filters: activeTag ? { tags: { $containsi: activeTag } } : undefined,
});

const articles = (articleEntries ?? []).map((entry) => entry.attributes as Article);

const allEntries = await getArticles();
const tagSet = new Set<string>();
(allEntries.data ?? []).forEach((entry) => {
  (entry.attributes as Article).tags?.forEach((tag) => tagSet.add(tag));
});
const tags = Array.from(tagSet).sort();

const pagination = meta?.pagination ?? { page: 1, pageCount: 1 };
---

<BaseLayout title="Blog" activePath="/blog">
  <section class="relative py-24 lg:py-32 bg-neutral-base dark:bg-neutral-950 overflow-hidden">
    <div class="absolute top-0 right-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6 space-y-16 relative z-10">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary shadow-sm dark:bg-neutral-900 dark:text-brand-light border border-neutral-100 dark:border-neutral-800 mb-6">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
          Blog
        </div>
        <h1 class="text-4xl md:text-5xl font-serif font-medium text-neutral-text dark:text-white mb-6">
          Pensieri e strumenti per la <span class="text-brand-primary italic">gestione del patrimonio</span>
        </h1>
        <p class="text-xl text-neutral-muted leading-relaxed dark:text-neutral-300 max-w-2xl">
          Analisi di scenario, metodologia e casi reali per navigare i mercati con lucidità e proteggere il patrimonio familiare.
        </p>
      </div>

      <div class="space-y-8">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <TagFilter tags={tags} activeTag={activeTag} basePath="/blog" />
          
          <div class="relative inline-block text-left">
            <select id="sort-select" class="block w-full rounded-full border border-neutral-200 bg-white px-4 py-2 pr-10 text-sm focus:border-brand-primary focus:outline-none dark:border-neutral-700 dark:bg-neutral-900 dark:text-white appearance-none cursor-pointer">
              <option value="recent">Più recenti</option>
              <option value="rated">Più votati</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-neutral-500">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </div>
          </div>
        </div>
        
        <div class="grid gap-8 md:grid-cols-3" id="articles-grid">
          {articles.length > 0 ? (
            articles.map((article) => (
              <div data-slug={article.slug} data-date={article.publishedAt} class="article-item h-full">
                <BlogCard article={article} />
              </div>
            ))
          ) : (
            <div class="col-span-full py-16 text-center rounded-[2.5rem] border border-dashed border-neutral-300 dark:border-neutral-700 bg-neutral-50/50 dark:bg-neutral-900/50">
              <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-neutral-100 text-neutral-400 mb-6 dark:bg-neutral-800">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                </svg>
              </div>
              <p class="text-xl font-medium text-neutral-900 dark:text-white mb-2">Nessun articolo trovato</p>
              <p class="text-neutral-500 dark:text-neutral-400 max-w-md mx-auto">
                Non ci sono articoli disponibili per i criteri di ricerca selezionati. Prova a rimuovere i filtri.
              </p>
            </div>
          )}
        </div>
        
        <Pagination
          page={pagination.page ?? 1}
          pageCount={pagination.pageCount ?? 1}
          basePath="/blog"
          query={{ tag: activeTag }}
        />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = createClient(supabaseUrl, supabaseAnonKey);

  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
  const grid = document.getElementById('articles-grid');
  const items = Array.from(document.querySelectorAll('.article-item'));

  let statsLoaded = false;
  let articleStats: Record<string, number> = {};

  async function loadStats() {
    if (statsLoaded) return;
    
    const { data, error } = await supabase
      .from('article_stats')
      .select('article_slug, average_rating');

    if (!error && data) {
      data.forEach((stat: any) => {
        articleStats[stat.article_slug] = stat.average_rating;
      });
    }
    statsLoaded = true;
  }

  async function sortArticles(criteria: string) {
    if (!grid) return;

    if (criteria === 'rated') {
      await loadStats();
      items.sort((a, b) => {
        const slugA = a.getAttribute('data-slug') || '';
        const slugB = b.getAttribute('data-slug') || '';
        const ratingA = articleStats[slugA] || 0;
        const ratingB = articleStats[slugB] || 0;
        return ratingB - ratingA;
      });
    } else {
      items.sort((a, b) => {
        const dateStrA = a.getAttribute('data-date') || '';
        const dateStrB = b.getAttribute('data-date') || '';
        const dateA = dateStrA ? new Date(dateStrA).getTime() : 0;
        const dateB = dateStrB ? new Date(dateStrB).getTime() : 0;
        return dateB - dateA;
      });
    }

    items.forEach(item => grid.appendChild(item));
  }

  if (sortSelect) {
    sortSelect.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      sortArticles(target.value);
    });
  }
</script>
