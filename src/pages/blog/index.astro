---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getArticles, getArticleStatsForSlugs, getUniqueArticleTags, getLatestPressItems, getLatestAudioPillole, type Article, type ArticleStats } from '../../lib/cms';

const page = Number(Astro.url.searchParams.get('page') ?? '1');
const activeTag = Astro.url.searchParams.get('tag') ?? undefined;
const searchQuery = Astro.url.searchParams.get('q') ?? undefined;
const searchLower = searchQuery?.toLowerCase() ?? '';

const [{ data: articleEntries, meta }, tags, allPress, allAudio] = await Promise.all([
  getArticles({
    pagination: { page, pageSize: 12 },
    filters: {
      ...(activeTag ? { tags: { $containsi: activeTag } } : {}),
      ...(searchQuery ? { q: searchQuery } : {}),
    },
  }),
  getUniqueArticleTags(),
  getLatestPressItems(6),
  getLatestAudioPillole(6),
]);

let articles = (articleEntries ?? []).map((entry) => entry.attributes as Article);

const pageSlugs = articles.map((a) => a.slug).filter(Boolean);
const pageStats = await getArticleStatsForSlugs(pageSlugs);
const statsMap = new Map<string, ArticleStats>(pageStats.map((s) => [s.article_slug, s]));

const latestPress = searchLower
  ? allPress.filter(p => p.title.toLowerCase().includes(searchLower) || (p.description ?? '').toLowerCase().includes(searchLower) || (p.testata ?? '').toLowerCase().includes(searchLower))
  : allPress.slice(0, 3);

const latestAudio = searchLower
  ? allAudio.filter(a => a.title.toLowerCase().includes(searchLower) || (a.description ?? '').toLowerCase().includes(searchLower))
  : allAudio.slice(0, 3);

const formatPressDate = (dateStr: string) => {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  const months = ['Gen', 'Feb', 'Mar', 'Apr', 'Mag', 'Giu', 'Lug', 'Ago', 'Set', 'Ott', 'Nov', 'Dic'];
  return `${months[d.getMonth()]} ${d.getFullYear()}`;
};

const pagination = meta?.pagination ?? { page: 1, pageCount: 1, total: 0 };
const totalArticles = (meta?.pagination as any)?.total ?? articles.length;
const totalResults = totalArticles + latestPress.length + latestAudio.length;
---

<BaseLayout 
  title="Blog" 
  description="Blog di Sergio Contegiacomo: articoli su gestione patrimoniale, finanza comportamentale, wealth management e strategie di investimento."
  keywords="blog finanza personale, articoli wealth management, consigli investimento, finanza comportamentale, educazione finanziaria"
  activePath="/blog"
>
  <section class="relative py-16 lg:py-24 bg-neutral-base dark:bg-neutral-950 overflow-hidden min-h-screen">
    <div class="absolute top-0 right-0 w-full h-full overflow-hidden pointer-events-none">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-brand-accent/5 rounded-full blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6 relative z-10">
      <!-- Header -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-primary shadow-sm dark:bg-neutral-900 dark:text-brand-light border border-neutral-100 dark:border-neutral-800 mb-4">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-primary dark:bg-brand-light"></span>
          Contenuti
        </div>
        <h1 class="text-3xl md:text-4xl font-serif font-medium text-neutral-text dark:text-white mb-4">
          Pensieri e strumenti per la <span class="text-brand-primary italic">gestione del patrimonio</span>
        </h1>
        <p class="text-neutral-muted dark:text-neutral-400 max-w-xl mx-auto">Articoli, audio, rassegna stampa e podcast in un unico punto di accesso.</p>
      </div>

      <!-- Barra ricerca cross-content -->
      <div class="bg-white dark:bg-neutral-900 rounded-2xl border border-neutral-200 dark:border-neutral-800 p-4 mb-10 shadow-sm">
        <form method="get" class="flex flex-col sm:flex-row gap-3">
          <div class="flex-1 relative">
            <input 
              type="text" 
              name="q" 
              value={searchQuery ?? ''}
              placeholder="Cerca tra articoli, audio, rassegna stampa..." 
              class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 pl-11 text-sm focus:border-brand-primary focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-primary/20 dark:border-neutral-700 dark:bg-neutral-800 dark:text-white dark:placeholder-neutral-400"
            />
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            {activeTag && <input type="hidden" name="tag" value={activeTag} />}
          </div>
          <div class="flex gap-2">
            <div class="relative">
              <select 
                id="tag-select" 
                class="appearance-none rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 pr-9 text-sm focus:border-brand-primary focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white cursor-pointer min-w-[130px]"
              >
                <option value="">Tutti i tag</option>
                {tags.map((tag) => (
                  <option value={tag} selected={activeTag === tag}>{tag}</option>
                ))}
              </select>
              <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
            <div class="relative">
              <select 
                id="sort-select" 
                class="appearance-none rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-3 pr-9 text-sm focus:border-brand-primary focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-white cursor-pointer min-w-[130px]"
              >
                <option value="recent">Recenti</option>
                <option value="oldest">Meno recenti</option>
                <option value="rated">Votati</option>
                <option value="az">A-Z</option>
              </select>
              <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
            <button type="submit" class="rounded-xl bg-brand-primary px-5 py-3 text-sm font-medium text-white hover:bg-brand-primary/90 transition flex-shrink-0">
              Cerca
            </button>
            {(activeTag || searchQuery) && (
              <a href="/blog" class="rounded-xl border border-red-200 bg-red-50 px-3 py-3 text-red-600 hover:bg-red-100 transition dark:border-red-800 dark:bg-red-900/20 dark:text-red-400 flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </a>
            )}
          </div>
        </form>

        <div class="flex flex-wrap items-center gap-2 mt-3 pt-3 border-t border-neutral-100 dark:border-neutral-800">
          {searchQuery ? (
            <span class="text-xs text-neutral-500 dark:text-neutral-400">
              {totalResults} {totalResults === 1 ? 'risultato' : 'risultati'} per "<span class="font-medium text-brand-primary">{searchQuery}</span>"
              {activeTag && <span> in <span class="font-medium text-brand-primary">{activeTag}</span></span>}
            </span>
          ) : (
            <span class="text-xs text-neutral-500 dark:text-neutral-400">
              {totalArticles} {totalArticles === 1 ? 'articolo' : 'articoli'}
              {activeTag && <span> in <span class="font-medium text-brand-primary">{activeTag}</span></span>}
            </span>
          )}
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 ml-auto">
              {tags.slice(0, 6).map((tag) => (
                <a 
                  href={activeTag === tag ? '/blog' : `/blog?tag=${encodeURIComponent(tag)}`}
                  class={`inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium transition ${
                    activeTag === tag 
                      ? 'bg-brand-primary text-white' 
                      : 'bg-neutral-100 text-neutral-600 hover:bg-brand-primary/10 hover:text-brand-primary dark:bg-neutral-800 dark:text-neutral-300'
                  }`}
                >
                  {tag}
                </a>
              ))}
              {tags.length > 6 && (
                <span class="text-xs text-neutral-400">+{tags.length - 6}</span>
              )}
            </div>
          )}
        </div>
      </div>

      <!-- ═══ Cross-content results: Audio + Press (when search or always) ═══ -->
      {(latestAudio.length > 0 || latestPress.length > 0) && (
        <div class="grid md:grid-cols-2 gap-6 mb-12">
          {/* AudioPillole */}
          {latestAudio.length > 0 && (
            <div>
              <div class="flex items-center justify-between mb-4">
                <h2 class="flex items-center gap-2 text-base font-semibold text-neutral-text dark:text-white">
                  <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-brand-primary/10 text-brand-primary">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
                  </span>
                  AudioPillole
                  {searchQuery && <span class="text-xs font-normal text-neutral-400">({latestAudio.length})</span>}
                </h2>
                <a href="/blog/audiopillole" class="text-xs font-medium text-brand-primary hover:text-brand-light transition flex items-center gap-1">
                  Tutte <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              </div>
              <div class="space-y-2">
                {latestAudio.map((audio) => (
                  <div class="audio-card group flex items-center gap-3 rounded-xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 px-4 py-3 hover:border-brand-primary/30 hover:shadow-md transition-all">
                    <button class="play-btn flex-shrink-0 w-9 h-9 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center hover:bg-brand-primary hover:text-white transition-all" data-audio-src={audio.file_url}>
                      <svg class="play-icon w-4 h-4 ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                      <svg class="pause-icon w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>
                    </button>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-sm font-medium text-neutral-text dark:text-white truncate group-hover:text-brand-primary transition-colors">{audio.title}</h3>
                      <div class="flex items-center gap-3 mt-0.5">
                        {audio.duration && <span class="text-[11px] text-neutral-400">{audio.duration}</span>}
                        <div class="hidden progress-wrap flex-1 items-center gap-2">
                          <div class="progress-container flex-1 h-1 bg-neutral-200 dark:bg-neutral-700 rounded-full cursor-pointer overflow-hidden">
                            <div class="progress-bar h-full bg-brand-primary rounded-full transition-all duration-100" style="width:0%"></div>
                          </div>
                          <span class="current-time text-[10px] font-mono text-neutral-400 w-7 text-right">0:00</span>
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              <audio id="blog-audio-player" preload="metadata" class="hidden"></audio>
            </div>
          )}

          {/* Rassegna Stampa */}
          {latestPress.length > 0 && (
            <div>
              <div class="flex items-center justify-between mb-4">
                <h2 class="flex items-center gap-2 text-base font-semibold text-neutral-text dark:text-white">
                  <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-rose-500/10 text-rose-500">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
                  </span>
                  Rassegna Stampa
                  {searchQuery && <span class="text-xs font-normal text-neutral-400">({latestPress.length})</span>}
                </h2>
                <a href="/blog/rassegna-stampa" class="text-xs font-medium text-brand-primary hover:text-brand-light transition flex items-center gap-1">
                  Tutte <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              </div>
              <div class="space-y-2">
                {latestPress.map((item) => (
                  <a
                    href={item.file_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-3 rounded-xl bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 px-4 py-3 hover:border-brand-primary/30 hover:shadow-md transition-all"
                  >
                    <div class="flex-shrink-0 w-10 h-12 rounded-lg bg-neutral-100 dark:bg-neutral-800 overflow-hidden relative flex items-center justify-center" data-pdf-thumb={item.file_url}>
                      <div class="pdf-placeholder absolute inset-0 flex items-center justify-center">
                        <svg class="h-5 w-5 text-red-400/60" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM9 13h6v1.5H9V13zm0 3h6v1.5H9V16zm0 3h4v1.5H9V19z"/></svg>
                      </div>
                      <canvas class="absolute inset-0 w-full h-full object-cover hidden"></canvas>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-sm font-medium text-neutral-text dark:text-white group-hover:text-brand-primary transition-colors truncate">{item.title}</h3>
                      <div class="flex items-center gap-2 mt-0.5">
                        {item.testata && <span class="text-[10px] font-bold uppercase tracking-wider text-brand-primary">{item.testata}</span>}
                        {item.published_at && <span class="text-[10px] text-neutral-400">{formatPressDate(item.published_at)}</span>}
                      </div>
                    </div>
                    <svg class="flex-shrink-0 h-4 w-4 text-neutral-300 dark:text-neutral-600 group-hover:text-brand-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      <!-- ═══ Articoli ═══ -->
      <div class="flex items-center justify-between mb-4">
        <h2 class="flex items-center gap-2 text-base font-semibold text-neutral-text dark:text-white">
          <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-blue-500/10 text-blue-500">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-2-2h-2" /></svg>
          </span>
          Articoli
          {searchQuery && <span class="text-xs font-normal text-neutral-400">({totalArticles})</span>}
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4" id="articles-grid">
        {articles.length > 0 ? (
          articles.map((article) => {
            const stats = statsMap.get(article.slug);
            return (
              <div 
                data-slug={article.slug} 
                data-date={article.publishedAt} 
                data-rating={stats?.average_rating ?? 0}
                data-title={article.title}
                class="article-item"
              >
                <BlogCard article={article} rating={stats?.average_rating} commentCount={stats?.comment_count} />
              </div>
            );
          })
        ) : (
          <div class="col-span-full py-16 text-center">
            <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-neutral-100 text-neutral-400 mb-4 dark:bg-neutral-800">
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <p class="text-lg font-medium text-neutral-900 dark:text-white mb-2">Nessun articolo trovato</p>
            <p class="text-sm text-neutral-500 dark:text-neutral-400 max-w-md mx-auto mb-6">
              Non ci sono articoli che corrispondono ai criteri di ricerca.
            </p>
            <a href="/blog" class="inline-flex items-center gap-2 rounded-full bg-brand-primary px-5 py-2.5 text-sm font-medium text-white hover:bg-brand-primary/90 transition">
              Vedi tutti gli articoli
            </a>
          </div>
        )}
      </div>
      
      {articles.length > 0 && (
        <div class="mt-12">
          <Pagination
            page={pagination.page ?? 1}
            pageCount={pagination.pageCount ?? 1}
            basePath="/blog"
            query={{ tag: activeTag, q: searchQuery }}
          />
        </div>
      )}

      <!-- Esplora sezioni -->
      <div class="mt-16 pt-12 border-t border-neutral-200 dark:border-neutral-800">
        <div class="grid sm:grid-cols-3 gap-4">
          <a href="/blog/audiopillole" class="group flex items-center gap-4 rounded-2xl bg-gradient-to-r from-brand-primary/10 to-brand-primary/5 dark:from-brand-primary/20 dark:to-brand-primary/5 border border-brand-primary/10 dark:border-brand-primary/20 p-5 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brand-primary/20 flex items-center justify-center text-brand-primary">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-text dark:text-white group-hover:text-brand-primary transition-colors">AudioPillole</h3>
              <p class="text-xs text-neutral-muted dark:text-neutral-400">Tutti i contenuti audio</p>
            </div>
            <svg class="h-5 w-5 ml-auto text-neutral-300 dark:text-neutral-600 group-hover:text-brand-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
          <a href="/blog/podcast" class="group flex items-center gap-4 rounded-2xl bg-gradient-to-r from-brand-accent/10 to-brand-accent/5 dark:from-brand-accent/20 dark:to-brand-accent/5 border border-brand-accent/10 dark:border-brand-accent/20 p-5 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brand-accent/20 flex items-center justify-center text-brand-accent">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-text dark:text-white group-hover:text-brand-accent transition-colors">Podcast</h3>
              <p class="text-xs text-neutral-muted dark:text-neutral-400">Episodi e interviste</p>
            </div>
            <svg class="h-5 w-5 ml-auto text-neutral-300 dark:text-neutral-600 group-hover:text-brand-accent group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
          <a href="/blog/rassegna-stampa" class="group flex items-center gap-4 rounded-2xl bg-gradient-to-r from-rose-500/10 to-rose-500/5 dark:from-rose-500/20 dark:to-rose-500/5 border border-rose-500/10 dark:border-rose-500/20 p-5 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-rose-500/20 flex items-center justify-center text-rose-500">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-text dark:text-white group-hover:text-rose-500 transition-colors">Rassegna Stampa</h3>
              <p class="text-xs text-neutral-muted dark:text-neutral-400">Articoli e pubblicazioni</p>
            </div>
            <svg class="h-5 w-5 ml-auto text-neutral-300 dark:text-neutral-600 group-hover:text-rose-500 group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const tagSelect = document.getElementById('tag-select') as HTMLSelectElement | null;
  if (tagSelect) {
    tagSelect.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      const url = new URL(window.location.href);
      if (target.value) {
        url.searchParams.set('tag', target.value);
      } else {
        url.searchParams.delete('tag');
      }
      url.searchParams.delete('page');
      window.location.href = url.toString();
    });
  }

  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
  const grid = document.getElementById('articles-grid');
  const items = Array.from(document.querySelectorAll('.article-item'));

  function sortArticles(criteria: string) {
    if (!grid || items.length === 0) return;
    items.sort((a, b) => {
      switch (criteria) {
        case 'rated':
          return parseFloat(b.getAttribute('data-rating') || '0') - parseFloat(a.getAttribute('data-rating') || '0');
        case 'oldest':
          return new Date(a.getAttribute('data-date') || '').getTime() - new Date(b.getAttribute('data-date') || '').getTime();
        case 'az':
          return (a.getAttribute('data-title') || '').localeCompare(b.getAttribute('data-title') || '', 'it');
        default:
          return new Date(b.getAttribute('data-date') || '').getTime() - new Date(a.getAttribute('data-date') || '').getTime();
      }
    });
    items.forEach(item => grid.appendChild(item));
  }

  if (sortSelect) {
    sortSelect.addEventListener('change', (e) => {
      sortArticles((e.target as HTMLSelectElement).value);
    });
  }
</script>

<script is:inline>
  (() => {
    const audioEl = document.getElementById('blog-audio-player');
    if (!audioEl) return;
    let activeCard = null;

    const fmt = (s) => {
      if (!s || !isFinite(s)) return '0:00';
      return Math.floor(s / 60) + ':' + String(Math.floor(s % 60)).padStart(2, '0');
    };

    const resetCard = (card) => {
      if (!card) return;
      card.querySelector('.play-icon')?.classList.remove('hidden');
      card.querySelector('.pause-icon')?.classList.add('hidden');
      const wrap = card.querySelector('.progress-wrap');
      if (wrap) wrap.classList.add('hidden');
      wrap?.classList.remove('flex');
    };

    document.querySelectorAll('.play-btn[data-audio-src]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.audio-card');
        const src = btn.getAttribute('data-audio-src');
        if (!card || !src) return;

        if (activeCard === card && !audioEl.paused) {
          audioEl.pause();
          resetCard(card);
          return;
        }

        if (activeCard && activeCard !== card) resetCard(activeCard);

        if (audioEl.getAttribute('src') !== src) {
          audioEl.src = src;
          audioEl.load();
        }

        audioEl.play();
        activeCard = card;
        card.querySelector('.play-icon')?.classList.add('hidden');
        card.querySelector('.pause-icon')?.classList.remove('hidden');
        const wrap = card.querySelector('.progress-wrap');
        if (wrap) { wrap.classList.remove('hidden'); wrap.classList.add('flex'); }
      });
    });

    audioEl.addEventListener('timeupdate', () => {
      if (!activeCard) return;
      const bar = activeCard.querySelector('.progress-bar');
      const cur = activeCard.querySelector('.current-time');
      if (bar) bar.style.width = (audioEl.currentTime / audioEl.duration * 100) + '%';
      if (cur) cur.textContent = fmt(audioEl.currentTime);
    });

    audioEl.addEventListener('loadedmetadata', () => {
      if (!activeCard) return;
      const dur = activeCard.querySelector('.duration');
      if (dur) dur.textContent = fmt(audioEl.duration);
    });

    audioEl.addEventListener('ended', () => {
      resetCard(activeCard);
      activeCard = null;
    });

    document.querySelectorAll('.progress-container').forEach((bar) => {
      bar.addEventListener('click', (e) => {
        if (!activeCard || !audioEl.duration) return;
        const rect = bar.getBoundingClientRect();
        audioEl.currentTime = ((e.clientX - rect.left) / rect.width) * audioEl.duration;
      });
    });
  })();
</script>

<script is:inline type="module">
  const pdfjsLib = await import('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/5.4.149/pdf.min.mjs');
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/5.4.149/pdf.worker.min.mjs';

  async function renderThumb(container) {
    const url = container.getAttribute('data-pdf-thumb');
    const canvas = container.querySelector('canvas');
    const placeholder = container.querySelector('.pdf-placeholder');
    if (!url || !canvas) return;
    try {
      const doc = await pdfjsLib.getDocument({ url, disableAutoFetch: true, disableStream: true }).promise;
      const page = await doc.getPage(1);
      const cW = container.offsetWidth, cH = container.offsetHeight;
      const vp = page.getViewport({ scale: 1 });
      const dpr = window.devicePixelRatio || 1;
      const scale = Math.max(cW / vp.width, cH / vp.height);
      const viewport = page.getViewport({ scale: scale * dpr });
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      canvas.style.width = cW + 'px';
      canvas.style.height = cH + 'px';
      await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
      canvas.classList.remove('hidden');
      if (placeholder) placeholder.classList.add('hidden');
      doc.destroy();
    } catch { /* fallback */ }
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { renderThumb(e.target); observer.unobserve(e.target); } });
  }, { rootMargin: '200px' });
  document.querySelectorAll('[data-pdf-thumb]').forEach((el) => observer.observe(el));
</script>
