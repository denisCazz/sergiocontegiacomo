---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPressItems } from '../../lib/cms';

const pressItems = await getPressItems();

const formatDate = (dateStr: string) => {
	if (!dateStr) return '';
	const date = new Date(dateStr);
	const months = ['Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno', 'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'];
	return `${months[date.getMonth()]} ${date.getFullYear()}`;
};

const featured = pressItems.length > 0 ? pressItems[0] : null;
const rest = pressItems.slice(1);
---

<BaseLayout title="Rassegna Stampa" description="Rassegna stampa e articoli pubblicati su Sergio Contegiacomo, consulente patrimoniale e coach finanziario." keywords="rassegna stampa Sergio Contegiacomo, articoli consulente patrimoniale, press consulenza finanziaria" activePath="/blog">
	<section class="relative py-24 lg:py-32 bg-neutral-base dark:bg-neutral-950 overflow-hidden">
		<div class="absolute inset-0 overflow-hidden pointer-events-none">
			<div class="absolute top-0 right-0 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
			<div class="absolute bottom-1/4 left-0 w-80 h-80 bg-brand-accent/5 rounded-full blur-3xl"></div>
		</div>

		<div class="mx-auto max-w-6xl px-6 relative z-10">
			<!-- Header -->
			<div class="text-center mb-16">
				<div class="inline-flex items-center gap-3 rounded-full bg-brand-primary/10 px-5 py-2 text-sm font-semibold uppercase tracking-wider text-brand-primary mb-6 border border-brand-primary/20 dark:bg-brand-primary/20 dark:text-brand-light">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
					</svg>
					Rassegna Stampa
				</div>
				<h1 class="text-4xl md:text-5xl font-serif font-medium text-neutral-text dark:text-white mb-6">
					Articoli e <span class="text-brand-primary italic">Interviste</span>
				</h1>
				<p class="text-xl text-neutral-muted leading-relaxed max-w-2xl mx-auto dark:text-neutral-400">
					Una raccolta dei miei contributi su testate giornalistiche, riviste specializzate e pubblicazioni di settore.
				</p>
			</div>

			{pressItems.length > 0 ? (
				<div class="space-y-12">
					{/* ── Featured (primo articolo) ── */}
					{featured && (
						<a
							href={featured.file_url}
							target="_blank"
							rel="noopener noreferrer"
							class="group block rounded-3xl border border-neutral-200 bg-white overflow-hidden shadow-sm transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 hover:border-brand-primary/30 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:border-brand-primary/50"
						>
							<div class="grid md:grid-cols-5 gap-0">
								<div class="md:col-span-2 relative bg-neutral-100 dark:bg-neutral-800 overflow-hidden">
									<div class="aspect-[3/4] md:aspect-auto md:h-full w-full relative flex items-center justify-center" data-pdf-thumb={featured.file_url} data-featured="true">
										<div class="pdf-placeholder absolute inset-0 flex items-center justify-center p-8">
											<div class="w-full max-w-[200px] bg-white dark:bg-neutral-700 rounded-lg shadow-lg border border-neutral-200 dark:border-neutral-600 p-5 space-y-3">
												<div class="flex items-center gap-2 mb-4">
													<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-500 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM9 13h6v1.5H9V13zm0 3h6v1.5H9V16zm0 3h4v1.5H9V19z"/></svg>
													<span class="text-[10px] font-bold uppercase text-red-500 tracking-wider">PDF</span>
												</div>
												<div class="space-y-2">
													<div class="h-2 bg-neutral-200 dark:bg-neutral-600 rounded-full w-full"></div>
													<div class="h-2 bg-neutral-200 dark:bg-neutral-600 rounded-full w-4/5"></div>
													<div class="h-2 bg-neutral-200 dark:bg-neutral-600 rounded-full w-full"></div>
													<div class="h-2 bg-neutral-200 dark:bg-neutral-600 rounded-full w-3/5"></div>
													<div class="h-2 bg-neutral-200 dark:bg-neutral-600 rounded-full w-full"></div>
													<div class="h-2 bg-neutral-200 dark:bg-neutral-600 rounded-full w-4/5"></div>
												</div>
												{featured.testata && (
													<p class="text-[9px] text-neutral-400 dark:text-neutral-500 text-center pt-2 border-t border-neutral-100 dark:border-neutral-600 uppercase tracking-wider">{featured.testata}</p>
												)}
											</div>
										</div>
										<canvas class="absolute inset-0 w-full h-full object-cover hidden" aria-label={`Anteprima: ${featured.title}`}></canvas>
										<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
									</div>
								</div>

								<div class="md:col-span-3 p-8 md:p-10 flex flex-col justify-center">
									<div class="flex flex-wrap items-center gap-3 mb-4">
										{featured.testata && (
											<span class="inline-flex items-center rounded-full bg-brand-primary/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-brand-primary dark:bg-brand-primary/20 dark:text-brand-light">
												{featured.testata}
											</span>
										)}
										{featured.published_at && (
											<span class="text-sm text-neutral-muted dark:text-neutral-500">{formatDate(featured.published_at)}</span>
										)}
									</div>
									<h2 class="text-2xl md:text-3xl font-serif font-semibold text-neutral-text dark:text-white mb-4 group-hover:text-brand-primary transition-colors">
										{featured.title}
									</h2>
									{featured.description && (
										<p class="text-neutral-muted dark:text-neutral-400 leading-relaxed mb-6 line-clamp-3">
											{featured.description}
										</p>
									)}
									<div class="flex items-center gap-2 text-brand-primary font-semibold text-sm group-hover:gap-3 transition-all">
										<span>Leggi l'articolo</span>
										<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
										</svg>
									</div>
								</div>
							</div>
						</a>
					)}

					{/* ── Griglia articoli restanti ── */}
					{rest.length > 0 && (
						<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
							{rest.map((article) => (
								<a
									href={article.file_url}
									target="_blank"
									rel="noopener noreferrer"
									class="group flex flex-col rounded-2xl border border-neutral-200 bg-white overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-brand-primary/30 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:border-brand-primary/50"
								>
									<div class="relative bg-neutral-100 dark:bg-neutral-800 overflow-hidden">
										<div class="aspect-[4/3] w-full relative flex items-center justify-center" data-pdf-thumb={article.file_url}>
											<div class="pdf-placeholder absolute inset-0 flex items-center justify-center p-6">
												<div class="w-full max-w-[140px] bg-white dark:bg-neutral-700 rounded-lg shadow-md border border-neutral-200 dark:border-neutral-600 p-4 space-y-2">
													<div class="flex items-center gap-1.5 mb-3">
														<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zM9 13h6v1.5H9V13zm0 3h6v1.5H9V16zm0 3h4v1.5H9V19z"/></svg>
														<span class="text-[9px] font-bold uppercase text-red-500 tracking-wider">PDF</span>
													</div>
													<div class="space-y-1.5">
														<div class="h-1.5 bg-neutral-200 dark:bg-neutral-600 rounded-full w-full"></div>
														<div class="h-1.5 bg-neutral-200 dark:bg-neutral-600 rounded-full w-3/4"></div>
														<div class="h-1.5 bg-neutral-200 dark:bg-neutral-600 rounded-full w-full"></div>
														<div class="h-1.5 bg-neutral-200 dark:bg-neutral-600 rounded-full w-2/3"></div>
													</div>
													{article.testata && (
														<p class="text-[8px] text-neutral-400 dark:text-neutral-500 text-center pt-1.5 border-t border-neutral-100 dark:border-neutral-600 uppercase tracking-wider">{article.testata}</p>
													)}
												</div>
											</div>
											<canvas class="absolute inset-0 w-full h-full object-cover hidden" aria-label={`Anteprima: ${article.title}`}></canvas>
											<div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
										</div>
									</div>

									<div class="flex-1 p-6 flex flex-col">
										<div class="flex flex-wrap items-center gap-2 mb-3">
											{article.testata && (
												<span class="inline-flex items-center rounded-full bg-brand-primary/10 px-2.5 py-0.5 text-[11px] font-bold uppercase tracking-wider text-brand-primary dark:bg-brand-primary/20 dark:text-brand-light">
													{article.testata}
												</span>
											)}
											{article.published_at && (
												<span class="text-xs text-neutral-muted dark:text-neutral-500">{formatDate(article.published_at)}</span>
											)}
										</div>
										<h3 class="text-lg font-semibold text-neutral-text dark:text-white group-hover:text-brand-primary transition-colors line-clamp-2 mb-2">
											{article.title}
										</h3>
										{article.description && (
											<p class="text-sm text-neutral-muted dark:text-neutral-400 leading-relaxed line-clamp-2 mb-3 flex-grow">
												{article.description}
											</p>
										)}
										<div class="flex items-center gap-1.5 text-brand-primary text-sm font-medium mt-auto pt-2">
											<span>Leggi</span>
											<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
											</svg>
										</div>
									</div>
								</a>
							))}
						</div>
					)}
				</div>
			) : (
				<div class="text-center py-20 rounded-3xl border-2 border-dashed border-neutral-200 dark:border-neutral-800 bg-neutral-50/50 dark:bg-neutral-900/50">
					<div class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-brand-primary/10 text-brand-primary mb-6">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
						</svg>
					</div>
					<h3 class="text-2xl font-semibold text-neutral-text dark:text-white mb-3">Nessun articolo disponibile</h3>
					<p class="text-neutral-muted dark:text-neutral-400 max-w-md mx-auto mb-6">
						La rassegna stampa e' in fase di aggiornamento. Torna presto per consultare gli articoli pubblicati!
					</p>
					<a href="/blog" class="inline-flex items-center gap-2 text-brand-primary hover:text-brand-light transition-colors font-medium">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
						</svg>
						Torna al Blog
					</a>
				</div>
			)}

			{pressItems.length > 0 && (
				<div class="text-center mt-16">
					<a href="/blog" class="inline-flex items-center gap-3 text-neutral-muted hover:text-brand-primary transition-colors group dark:text-neutral-400">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
						</svg>
						Torna al Blog
					</a>
				</div>
			)}
		</div>
	</section>

	<script is:inline type="module">
		const pdfjsLib = await import('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/5.4.149/pdf.min.mjs');
		pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/5.4.149/pdf.worker.min.mjs';

		async function renderThumb(container) {
			const url = container.getAttribute('data-pdf-thumb');
			const canvas = container.querySelector('canvas');
			const placeholder = container.querySelector('.pdf-placeholder');
			if (!url || !canvas) return;

			try {
				const doc = await pdfjsLib.getDocument({ url, disableAutoFetch: true, disableStream: true }).promise;
				const page = await doc.getPage(1);

				const containerW = container.offsetWidth;
				const containerH = container.offsetHeight;
				const vp = page.getViewport({ scale: 1 });

				const dpr = window.devicePixelRatio || 1;
				const scaleW = containerW / vp.width;
				const scaleH = containerH / vp.height;
				const scale = Math.max(scaleW, scaleH);

				const viewport = page.getViewport({ scale: scale * dpr });
				canvas.width = viewport.width;
				canvas.height = viewport.height;
				canvas.style.width = containerW + 'px';
				canvas.style.height = containerH + 'px';

				const ctx = canvas.getContext('2d');
				await page.render({ canvasContext: ctx, viewport }).promise;

				canvas.classList.remove('hidden');
				if (placeholder) placeholder.classList.add('hidden');
				doc.destroy();
			} catch {
				if (placeholder) {
					const spinner = placeholder.querySelector('.animate-spin');
					if (spinner) spinner.remove();
				}
			}
		}

		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					renderThumb(entry.target);
					observer.unobserve(entry.target);
				}
			});
		}, { rootMargin: '200px' });

		document.querySelectorAll('[data-pdf-thumb]').forEach((el) => observer.observe(el));
	</script>
</BaseLayout>
